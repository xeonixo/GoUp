{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">Allgemein</a>
    <a href="/admin/tenants" class="admin-nav-link">Tenants</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/providers" class="admin-nav-link">OCID-Provider</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/local-users" class="admin-nav-link is-active">Benutzerverwaltung</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/remote-nodes" class="admin-nav-link">Remote Nodes</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>Benutzerverwaltung · {{.AdminTenant.Name}}</h1>
    </div>
    <div class="admin-actions-inline">
      <a href="/admin/tenants/{{.AdminTenant.ID}}/providers" class="button button-secondary">OCID-Provider</a>
      <a href="/admin/tenants/{{.AdminTenant.ID}}/local-users/new" class="button">+ Lokaler Benutzer</a>
    </div>
  </div>

  <div class="card table-card">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Login</th>
        <th>Typ</th>
        <th>Name</th>
        <th>E-Mail</th>
        <th>Rolle</th>
        <th>Letzter Login</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      {{if .AdminTenantUsers}}
      {{range .AdminTenantUsers}}
      <tr>
        <td>{{if .LoginName}}{{.LoginName}}{{else}}—{{end}}</td>
        <td>
          {{if .HasLocalCredentials}}<span class="status-badge">LOCAL</span>{{end}}
          {{if .HasOIDCIdentity}}<span class="status-badge">OIDC</span>{{end}}
          {{if and (not .HasLocalCredentials) (not .HasOIDCIdentity)}}<span class="status-badge status-badge-muted">UNK</span>{{end}}
        </td>
        <td>{{.DisplayName}}</td>
        <td>{{.Email}}</td>
        <td><span class="status-badge">{{.Role}}</span></td>
        <td>{{if .LastLoginAt}}<span class="js-local-datetime" data-utc="{{.LastLoginAt.Format "2006-01-02T15:04:05Z07:00"}}">{{.LastLoginAt}}</span>{{else}}—{{end}}</td>
        <td class="admin-actions-inline">
          {{if .HasLocalCredentials}}
          <a href="/admin/tenants/{{$.AdminTenant.ID}}/local-users/{{.UserID}}/edit" class="button button-secondary button-small">Bearbeiten</a>
          {{end}}
          <form method="POST" action="/admin/tenants/{{$.AdminTenant.ID}}/users/{{.UserID}}/remove" class="inline-form" data-confirm="Benutzer wirklich aus diesem Tenant entfernen?">
            <button type="submit" class="button button-danger button-small">Aus Tenant entfernen</button>
          </form>
        </td>
      </tr>
      {{end}}
      {{else}}
      <tr>
        <td colspan="7" class="muted">Keine Benutzer vorhanden.</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
</div>
{{end}}

{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">{{index $.Translations "admin.nav.general"}}</a>
    <a href="/admin/tenants" class="admin-nav-link">{{index $.Translations "admin.nav.tenants"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/providers" class="admin-nav-link">{{index $.Translations "admin.nav.providers"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/local-users" class="admin-nav-link is-active">{{index $.Translations "admin.nav.users"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/remote-nodes" class="admin-nav-link">{{index $.Translations "admin.nav.remote_nodes"}}</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>{{index $.Translations "admin.nav.users"}} · {{.AdminTenant.Name}}</h1>
    </div>
    <div class="admin-actions-inline">
      <a href="/admin/tenants/{{.AdminTenant.ID}}/providers" class="button button-secondary">{{index $.Translations "admin.nav.providers"}}</a>
      <a href="/admin/tenants/{{.AdminTenant.ID}}/local-users/new" class="button">{{index $.Translations "admin.local_users.new_button"}}</a>
    </div>
  </div>

  <div class="card table-card">
  <table class="admin-table">
    <thead>
      <tr>
        <th>{{index $.Translations "admin.local_users.login_label"}}</th>
        <th>{{index $.Translations "admin.local_users.type_label"}}</th>
        <th>{{index $.Translations "admin.local_users.name_label"}}</th>
        <th>{{index $.Translations "admin.local_users.email_label"}}</th>
        <th>{{index $.Translations "admin.local_users.role_label"}}</th>
        <th>{{index $.Translations "field.last_login"}}</th>
        <th>{{index $.Translations "admin.local_users.actions_label"}}</th>
      </tr>
    </thead>
    <tbody>
      {{if .AdminTenantUsers}}
      {{range .AdminTenantUsers}}
      <tr>
        <td>{{if .LoginName}}{{.LoginName}}{{else}}—{{end}}</td>
        <td>
          {{if .HasLocalCredentials}}<span class="status-badge">LOCAL</span>{{end}}
          {{if .HasOIDCIdentity}}<span class="status-badge">OIDC</span>{{end}}
          {{if and (not .HasLocalCredentials) (not .HasOIDCIdentity)}}<span class="status-badge status-badge-muted">UNK</span>{{end}}
        </td>
        <td>{{.DisplayName}}</td>
        <td>{{.Email}}</td>
        <td><span class="status-badge">{{.Role}}</span></td>
        <td>{{if .LastLoginAt}}<span class="js-local-datetime" data-utc="{{.LastLoginAt.Format "2006-01-02T15:04:05Z07:00"}}">{{.LastLoginAt}}</span>{{else}}—{{end}}</td>
        <td class="admin-actions-inline">
          {{if .HasLocalCredentials}}
          <a href="/admin/tenants/{{$.AdminTenant.ID}}/local-users/{{.UserID}}/edit" class="button button-secondary button-small">{{index $.Translations "admin.local_users.edit_button"}}</a>
          {{end}}
          <form method="POST" action="/admin/tenants/{{$.AdminTenant.ID}}/users/{{.UserID}}/remove" class="inline-form" data-confirm="{{index $.Translations "admin.local_users.remove_confirm"}}">
            <button type="submit" class="button button-danger button-small">{{index $.Translations "admin.local_users.remove_button"}}</button>
          </form>
        </td>
      </tr>
      {{end}}
      {{else}}
      <tr>
        <td colspan="7" class="muted">{{index $.Translations "admin.users.no_users"}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
</div>
{{end}}

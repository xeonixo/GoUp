{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">Allgemein</a>
    <a href="/admin/tenants" class="admin-nav-link">Tenants</a>
    <a href="/admin/providers" class="admin-nav-link">OCID-Provider</a>
    <a href="/admin/users" class="admin-nav-link is-active">Benutzerverwaltung</a>
    <a href="/admin/remote-nodes" class="admin-nav-link">Remote Nodes</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>Benutzerverwaltung</h1>
    </div>
  </div>

  <div class="card table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Tenant</th>
          <th>Login</th>
          <th>Typ</th>
          <th>Name</th>
          <th>E-Mail</th>
          <th>Rolle</th>
          <th>Letzter Login</th>
          <th>Aktionen</th>
        </tr>
      </thead>
      <tbody>
        {{if .AdminUserRows}}
        {{range .AdminUserRows}}
        <tr>
          <td>{{.TenantName}}</td>
          <td>{{if .LoginName}}{{.LoginName}}{{else}}—{{end}}</td>
          <td>
            {{if .HasLocalCredentials}}<span class="status-badge">LOCAL</span>{{end}}
            {{if .HasOIDCIdentity}}<span class="status-badge">OIDC</span>{{end}}
            {{if and (not .HasLocalCredentials) (not .HasOIDCIdentity)}}<span class="status-badge status-badge-muted">UNK</span>{{end}}
          </td>
          <td>{{.DisplayName}}</td>
          <td>{{.Email}}</td>
          <td><span class="status-badge">{{.Role}}</span></td>
          <td>{{if .LastLoginAtRaw}}<span class="js-local-datetime" data-utc="{{.LastLoginAtRaw}}">{{.LastLoginAt}}</span>{{else}}—{{end}}</td>
          <td class="admin-actions-inline">
            <a href="/admin/tenants/{{.TenantID}}/local-users" class="button button-secondary button-small">Tenant öffnen</a>
          </td>
        </tr>
        {{end}}
        {{else}}
        <tr>
          <td colspan="8" class="muted">Keine Benutzer vorhanden.</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}

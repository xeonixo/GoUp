{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">{{index $.Translations "admin.nav.general"}}</a>
    <a href="/admin/tenants" class="admin-nav-link">{{index $.Translations "admin.nav.tenants"}}</a>
    <a href="/admin/providers" class="admin-nav-link">{{index $.Translations "admin.nav.providers"}}</a>
    <a href="/admin/users" class="admin-nav-link is-active">{{index $.Translations "admin.nav.users"}}</a>
    <a href="/admin/remote-nodes" class="admin-nav-link">{{index $.Translations "admin.nav.remote_nodes"}}</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>{{index $.Translations "admin.nav.users"}}</h1>
    </div>
  </div>

  <div class="card table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>{{index $.Translations "admin.users.tenant"}}</th>
          <th>{{index $.Translations "field.login"}}</th>
          <th>{{index $.Translations "common.type"}}</th>
          <th>{{index $.Translations "common.name"}}</th>
          <th>{{index $.Translations "field.email"}}</th>
          <th>{{index $.Translations "admin.users.role"}}</th>
          <th>{{index $.Translations "admin.users.last_login"}}</th>
          <th>{{index $.Translations "common.actions"}}</th>
        </tr>
      </thead>
      <tbody>
        {{if .AdminUserRows}}
        {{range .AdminUserRows}}
        <tr>
          <td>{{.TenantName}}</td>
          <td>{{if .LoginName}}{{.LoginName}}{{else}}—{{end}}</td>
          <td>
            {{if .HasLocalCredentials}}<span class="status-badge">LOCAL</span>{{end}}
            {{if .HasOIDCIdentity}}<span class="status-badge">OIDC</span>{{end}}
            {{if and (not .HasLocalCredentials) (not .HasOIDCIdentity)}}<span class="status-badge status-badge-muted">UNK</span>{{end}}
          </td>
          <td>{{.DisplayName}}</td>
          <td>{{.Email}}</td>
          <td><span class="status-badge">{{.Role}}</span></td>
          <td>{{if .LastLoginAtRaw}}<span class="js-local-datetime" data-utc="{{.LastLoginAtRaw}}">{{.LastLoginAt}}</span>{{else}}—{{end}}</td>
          <td class="admin-actions-inline">
            <a href="/admin/tenants/{{.TenantID}}/local-users" class="button button-secondary button-small">{{index $.Translations "admin.users.open_tenant"}}</a>
          </td>
        </tr>
        {{end}}
        {{else}}
        <tr>
          <td colspan="8" class="muted">{{index $.Translations "admin.users.no_users"}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}

{{define "content"}}
<div class="admin-section" id="settings-remote-nodes-page" data-app-base="{{$.AppBase}}">
  <nav class="admin-nav card">
    <a href="{{$.AppBase}}" class="admin-nav-link">Dashboard</a>
    <a href="{{$.AppBase}}settings/profile" class="admin-nav-link">Profil</a>
    <a href="{{$.AppBase}}settings/users" class="admin-nav-link">Benutzerverwaltung</a>
    <a href="{{$.AppBase}}settings/providers" class="admin-nav-link">OCID-Provider</a>
    <a href="{{$.AppBase}}settings/remote-nodes" class="admin-nav-link is-active">Remote Nodes</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>Remote Nodes</h1>
    </div>
  </div>

  <form method="post" action="{{$.AppBase}}settings/remote-nodes/create" class="admin-form card stack">
    <div class="inline-grid">
      <label>
        <span>Name</span>
        <input type="text" name="name" placeholder="z. B. Werkhalle-Node" required>
      </label>
      <label>
        <span>Heartbeat Timeout (Sek.)</span>
        <input type="number" name="heartbeat_timeout_seconds" min="30" value="120" required>
      </label>
    </div>
    <div class="form-actions">
      <button class="button" type="submit">+ Remote-Node erstellen</button>
    </div>
  </form>

  <div class="card table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Node ID</th>
          <th>Status</th>
          <th>Zuletzt gesehen</th>
          <th>Timeout</th>
          <th>Provisioning URL</th>
          <th>Protokoll</th>
          <th>Aktionen</th>
        </tr>
      </thead>
      <tbody id="settings-remote-nodes-body">
        {{if .RemoteNodes}}
        {{range .RemoteNodes}}
        <tr data-node-id="{{.NodeID}}">
          <td>{{.Name}}</td>
          <td class="break-all"><code>{{.NodeID}}</code></td>
          <td data-role="status">{{if .Online}}<span class="status-badge status-badge-success">ONLINE</span>{{else}}<span class="status-badge status-badge-muted">OFFLINE</span>{{end}}</td>
          <td data-role="last-seen">{{if .LastSeenAtRaw}}<span class="js-relative-age" data-utc="{{.LastSeenAtRaw}}">{{.LastSeenAt}}</span>{{else}}—{{end}}</td>
          <td>{{.HeartbeatWindow}}</td>
          <td class="break-all">{{.ProvisionURL}}</td>
          <td data-role="logs">
            {{if .Events}}
            <details class="remote-node-log">
              <summary>{{len .Events}} Einträge</summary>
              <ul class="remote-node-log-list">
                {{range .Events}}
                <li>
                  <div><strong>{{.EventLabel}}</strong> · <span class="js-relative-age" data-utc="{{.OccurredAtRaw}}">{{.OccurredAt}}</span></div>
                  <div class="muted compact break-all">Von {{.SourceIP}}{{if .Details}} · {{.Details}}{{end}}{{if .UserAgent}} · {{.UserAgent}}{{end}}</div>
                </li>
                {{end}}
              </ul>
            </details>
            {{else}}
            <span class="muted">—</span>
            {{end}}
          </td>
          <td class="admin-actions-inline">
            <form method="post" action="{{$.AppBase}}settings/remote-nodes/{{.NodeID}}/rotate-bootstrap" class="inline-form" data-confirm="Bootstrap-Key wirklich neu erstellen? Alte Deployments mit altem Key können dann nicht mehr neu bootstrappen.">
              <button class="button button-secondary button-small" type="submit">Bootstrap-Key rotieren</button>
            </form>
            <form method="post" action="{{$.AppBase}}settings/remote-nodes/{{.NodeID}}/delete" class="inline-form" data-confirm="Remote-Node wirklich löschen? Zugewiesene Monitore werden lokal ausgeführt.">
              <button class="button button-danger button-small" type="submit">Löschen</button>
            </form>
          </td>
        </tr>
        {{end}}
        {{else}}
        <tr>
          <td colspan="8" class="muted">Noch keine Remote-Nodes vorhanden.</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}

{{define "page_scripts"}}
<script src="/static/settings-remote-nodes.js" defer></script>
{{end}}

{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">{{index $.Translations "admin.nav.general"}}</a>
    <a href="/admin/tenants" class="admin-nav-link is-active">{{index $.Translations "admin.nav.tenants"}}</a>
    <a href="/admin/providers" class="admin-nav-link">{{index $.Translations "admin.nav.providers"}}</a>
    <a href="/admin/users" class="admin-nav-link">{{index $.Translations "admin.nav.users"}}</a>
    <a href="/admin/remote-nodes" class="admin-nav-link">{{index $.Translations "admin.nav.remote_nodes"}}</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>{{index $.Translations "admin.nav.tenants"}}</h1>
    </div>
    <a href="/admin/tenants/new" class="button">+ {{index $.Translations "admin.tenants.new_tenant"}}</a>
  </div>

  <div class="card table-card">
  <table class="admin-table">
    <thead>
      <tr>
        <th>{{index $.Translations "admin.tenants.id"}}</th>
        <th>{{index $.Translations "admin.tenants.slug"}}</th>
        <th>{{index $.Translations "common.name"}}</th>
        <th>{{index $.Translations "admin.tenants.db_path"}}</th>
        <th>{{index $.Translations "common.status"}}</th>
        <th>{{index $.Translations "common.actions"}}</th>
      </tr>
    </thead>
    <tbody>
      {{if .AdminTenants}}
      {{range .AdminTenants}}
      <tr>
        <td>{{.ID}}</td>
        <td>{{.Slug}}</td>
        <td>{{.Name}}</td>
        <td class="break-all">{{.DBPath}}</td>
        <td>
          {{if .Active}}
          <span class="status-badge status-badge-success">{{index $.Translations "common.active"}}</span>
          {{else}}
          <span class="status-badge status-badge-muted">{{index $.Translations "common.inactive"}}</span>
          {{end}}
        </td>
        <td class="admin-actions-inline">
          <a href="/admin/tenants/{{.ID}}/edit" class="button button-secondary button-small">{{index $.Translations "common.edit"}}</a>
          <a href="/admin/tenants/{{.ID}}/providers" class="button button-secondary button-small">{{index $.Translations "admin.nav.providers"}}</a>
          <a href="/admin/tenants/{{.ID}}/local-users" class="button button-secondary button-small">{{index $.Translations "admin.tenants.local_users"}}</a>
          <a href="/admin/tenants/{{.ID}}/remote-nodes" class="button button-secondary button-small">{{index $.Translations "admin.nav.remote_nodes"}}</a>
          {{if .Active}}
          <form method="POST" action="/admin/tenants/{{.ID}}/delete" class="inline-form" data-confirm="{{index $.Translations "admin.tenants.confirm_deactivate"}}">
            <button type="submit" class="button button-danger button-small">{{index $.Translations "admin.tenants.deactivate"}}</button>
          </form>
          {{end}}
          <form method="POST" action="/admin/tenants/{{.ID}}/purge" class="inline-form" data-confirm="{{index $.Translations "admin.tenants.confirm_purge"}}">
            <button type="submit" class="button button-danger button-small">{{index $.Translations "admin.tenants.purge"}}</button>
          </form>
        </td>
      </tr>
      {{end}}
      {{else}}
      <tr>
        <td colspan="6" class="muted">{{index $.Translations "admin.tenants.no_tenants"}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>
</div>
{{end}}

{{define "content"}}
<section class="card stack narrow">
  <h1>{{index $.Translations "password_reset.request.title"}}</h1>
  <p>{{index $.Translations "login.tenant_label"}} <strong>{{.TenantName}}</strong></p>

  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}
  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}

  <form method="POST" action="/{{.TenantSlug}}/password-reset/request" class="stack">
    <label for="email">{{index $.Translations "password_reset.request.email_label"}}</label>
    <input id="email" name="email" type="email" required autocomplete="email" placeholder="{{index $.Translations "password_reset.request.email_placeholder"}}">
    <button type="submit" class="button">{{index $.Translations "password_reset.request.submit_button"}}</button>
    <a href="/{{.TenantSlug}}/login" class="button button-secondary">{{index $.Translations "password_reset.request.back_to_login"}}</a>
  </form>
</section>
{{end}}

{{define "content"}}
<section class="card stack narrow">
  <h1>Passwort zurücksetzen</h1>
  <p>Tenant: <strong>{{.TenantName}}</strong></p>

  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}
  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}

  <form method="POST" action="/t/{{.TenantSlug}}/password-reset/request" class="stack">
    <label for="email">E-Mail-Adresse</label>
    <input id="email" name="email" type="email" required autocomplete="email" placeholder="name@example.com">
    <button type="submit" class="button">Reset-Link senden</button>
    <a href="/t/{{.TenantSlug}}/login" class="button button-secondary">Zurück zum Login</a>
  </form>
</section>
{{end}}

{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">{{index $.Translations "admin.nav.general"}}</a>
    <a href="/admin/tenants" class="admin-nav-link">{{index $.Translations "admin.nav.tenants"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/providers" class="admin-nav-link">{{index $.Translations "admin.nav.providers"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/local-users" class="admin-nav-link">{{index $.Translations "admin.nav.users"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/remote-nodes" class="admin-nav-link is-active">{{index $.Translations "admin.nav.remote_nodes"}}</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>{{index $.Translations "admin.remote_nodes.title"}} · {{.AdminTenant.Name}}</h1>
    </div>
    <a href="/admin/tenants" class="button button-secondary">{{index $.Translations "admin.remote_nodes.back_to_tenants"}}</a>
  </div>

  <form method="post" action="/admin/tenants/{{.AdminTenant.ID}}/remote-nodes/create" class="admin-form card stack">
    <div class="inline-grid">
      <label>
        <span>{{index $.Translations "admin.remote_nodes.name_label"}}</span>
        <input type="text" name="name" placeholder="{{index $.Translations "admin.remote_nodes.name_placeholder"}}" required>
      </label>
      <label>
        <span>{{index $.Translations "admin.remote_nodes.heartbeat_timeout_label"}}</span>
        <input type="number" name="heartbeat_timeout_seconds" min="30" value="120" required>
      </label>
    </div>
    <div class="form-actions">
      <button class="button" type="submit">{{index $.Translations "admin.remote_nodes.create_button"}}</button>
    </div>
  </form>

  <div class="card table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>{{index $.Translations "admin.remote_nodes.name_label"}}</th>
          <th>{{index $.Translations "admin.remote_nodes.node_id_label"}}</th>
          <th>{{index $.Translations "admin.remote_nodes.status_label"}}</th>
          <th>{{index $.Translations "admin.remote_nodes.last_seen_label"}}</th>
          <th>{{index $.Translations "admin.remote_nodes.timeout_label"}}</th>
          <th>{{index $.Translations "admin.remote_nodes.provisioning_url_label"}}</th>
          <th>{{index $.Translations "admin.remote_nodes.protocol_label"}}</th>
          <th>{{index $.Translations "admin.remote_nodes.actions_label"}}</th>
        </tr>
      </thead>
      <tbody>
        {{if .RemoteNodes}}
        {{range .RemoteNodes}}
        <tr>
          <td>{{.Name}}</td>
          <td class="break-all"><code>{{.NodeID}}</code></td>
          <td>{{if .Online}}<span class="status-badge status-badge-success">ONLINE</span>{{else}}<span class="status-badge status-badge-muted">OFFLINE</span>{{end}}</td>
          <td>{{if .LastSeenAtRaw}}<span class="js-relative-age" data-utc="{{.LastSeenAtRaw}}">{{.LastSeenAt}}</span>{{else}}—{{end}}</td>
          <td>{{.HeartbeatWindow}}</td>
          <td class="break-all">{{.ProvisionURL}}</td>
          <td>
            {{if .Events}}
            <details class="remote-node-log">
              <summary>{{len .Events}} {{index $.Translations "admin.remote_nodes.entries"}}</summary>
              <ul class="remote-node-log-list">
                {{range .Events}}
                <li>
                  <div><strong>{{.EventLabel}}</strong> · <span class="js-relative-age" data-utc="{{.OccurredAtRaw}}">{{.OccurredAt}}</span></div>
                  <div class="muted compact break-all">{{index $.Translations "admin.remote_nodes.from"}} {{.SourceIP}}{{if .Details}} · {{.Details}}{{end}}{{if .UserAgent}} · {{.UserAgent}}{{end}}</div>
                </li>
                {{end}}
              </ul>
            </details>
            {{else}}
            <span class="muted">—</span>
            {{end}}
          </td>
          <td class="admin-actions-inline">
            <form method="post" action="/admin/tenants/{{$.AdminTenant.ID}}/remote-nodes/{{.NodeID}}/rotate-bootstrap" class="inline-form" data-confirm="{{index $.Translations "admin.remote_nodes.rotate_bootstrap_confirm"}}">
              <button class="button button-secondary button-small" type="submit">{{index $.Translations "admin.remote_nodes.rotate_bootstrap_button"}}</button>
            </form>
            <form method="post" action="/admin/tenants/{{$.AdminTenant.ID}}/remote-nodes/{{.NodeID}}/delete" class="inline-form" data-confirm="{{index $.Translations "admin.remote_nodes.delete_with_reassign_confirm"}}">
              <button class="button button-danger button-small" type="submit">{{index $.Translations "admin.remote_nodes.delete_button"}}</button>
            </form>
          </td>
        </tr>
        {{end}}
        {{else}}
        <tr>
          <td colspan="8" class="muted">{{index $.Translations "admin.remote_nodes.no_remote_nodes"}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}

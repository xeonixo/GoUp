{{define "layout"}}
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <header class="topbar">
    <div class="topbar-main">
      <a class="brand" href="{{if .AppBase}}{{.AppBase}}{{else}}/{{end}}">GoUp</a>
      {{if and .User .User.TenantSlug}}
      <span class="subtitle">Tenant: {{if .User.TenantName}}{{.User.TenantName}}{{else}}{{.User.TenantSlug}}{{end}}</span>
      {{end}}
      <span class="subtitle" id="client-timezone-info" hidden></span>
    </div>
    {{block "topbar_actions" .}}{{end}}
    <nav class="topbar-nav">
      {{if .User}}
      <span class="user-pill">{{if .User.Name}}{{.User.Name}}{{else}}{{.User.Email}}{{end}}</span>
      <a class="button button-secondary topbar-icon-link" href="{{.AppBase}}settings/profile" aria-label="Settings" title="Settings">
        <span aria-hidden="true">⚙️</span>
        <span class="sr-only">Settings</span>
      </a>
      <a class="button button-secondary topbar-icon-link" href="/auth/logout" aria-label="Logout" title="Logout">
        <span aria-hidden="true">⎋</span>
        <span class="sr-only">Logout</span>
      </a>
      {{end}}
    </nav>
  </header>
  <main class="container">
    {{template "content" .}}
  </main>
  <script>
    (function () {
      var scrollKey = "goup:scroll:" + window.location.pathname;

      window.addEventListener("beforeunload", function () {
        try {
          sessionStorage.setItem(scrollKey, String(window.scrollY || 0));
        } catch (_) {}
      });

      window.addEventListener("DOMContentLoaded", function () {
        try {
          var currentURL = new URL(window.location.href);
          var changed = false;
          if (currentURL.searchParams.has("error")) {
            currentURL.searchParams.delete("error");
            changed = true;
          }
          if (currentURL.searchParams.has("notice")) {
            currentURL.searchParams.delete("notice");
            changed = true;
          }
          if (changed) {
            var next = currentURL.pathname;
            var qs = currentURL.searchParams.toString();
            if (qs) {
              next += "?" + qs;
            }
            if (currentURL.hash) {
              next += currentURL.hash;
            }
            history.replaceState({}, "", next);
          }
        } catch (_) {}

        try {
          if (!window.location.hash) {
            var y = parseInt(sessionStorage.getItem(scrollKey) || "0", 10);
            if (!isNaN(y) && y > 0) {
              window.scrollTo({ top: y, behavior: "auto" });
            }
          }
        } catch (_) {}

        var nodes = document.querySelectorAll(".js-local-datetime[data-utc]");
        for (var i = 0; i < nodes.length; i++) {
          var el = nodes[i];
          var raw = el.getAttribute("data-utc");
          if (!raw) continue;
          var d = new Date(raw);
          if (isNaN(d.getTime())) continue;
          el.textContent = d.toLocaleString();
          el.title = raw;
        }

        var timezoneInfo = document.getElementById("client-timezone-info");
        if (timezoneInfo) {
          var timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
          if (timezone) {
            timezoneInfo.textContent = "TZ: " + timezone;
            timezoneInfo.hidden = false;
          }
        }
      });
    })();
  </script>
</body>
</html>
{{end}}

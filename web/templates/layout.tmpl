{{define "layout"}}
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
  <link rel="stylesheet" href="/static/style.css">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="manifest" href="/site.webmanifest">
</head>
<body>
  {{if not .HideTopbar}}
  <header class="topbar">
    <div class="topbar-main">
      <a class="brand" href="{{if .AppBase}}{{.AppBase}}{{else}}/{{end}}">
        <img class="brand-logo" src="/assets/logo_goup.svg" alt="GoUp Logo">
      </a>
      {{if .ControlPlaneAdmin}}
      <span class="subtitle">Control Plane</span>
      {{else if and .User .User.TenantSlug}}
      <span class="subtitle">Tenant: {{if .User.TenantName}}{{.User.TenantName}}{{else}}{{.User.TenantSlug}}{{end}}</span>
      {{end}}
    </div>
    <button class="topbar-hamburger" id="topbar-hamburger" type="button" aria-label="Menü öffnen" aria-expanded="false" aria-controls="topbar-collapsible">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
    <div class="topbar-collapsible" id="topbar-collapsible">
      {{block "topbar_actions" .}}{{end}}
      <nav class="topbar-nav">
        {{if .ControlPlaneAdmin}}
        <span class="user-pill">Admin Access</span>
        <a class="button button-secondary topbar-icon-link" href="/admin/security" aria-label="Control-Plane Sicherheit" title="Control-Plane Sicherheit">
          <span aria-hidden="true">⚙️</span>
          <span class="sr-only">Control-Plane Sicherheit</span>
        </a>
        <a class="button button-secondary topbar-icon-link" href="/admin/access?logout=1" aria-label="Control-Plane Logout" title="Control-Plane Logout">
          <span aria-hidden="true">⎋</span>
          <span class="sr-only">Abmelden</span>
        </a>
        {{else if .User}}
        <span class="user-pill">{{if .User.Name}}{{.User.Name}}{{else}}{{.User.Email}}{{end}}</span>
        <a class="button button-secondary topbar-icon-link" href="{{.AppBase}}settings/profile" aria-label="Einstellungen" title="Einstellungen">
          <span aria-hidden="true">⚙️</span>
          <span class="sr-only">Einstellungen</span>
        </a>
        <a class="button button-secondary topbar-icon-link" href="/auth/logout" aria-label="Abmelden" title="Abmelden">
          <span aria-hidden="true">⎋</span>
          <span class="sr-only">Abmelden</span>
        </a>
        {{end}}
      </nav>
    </div>
  </header>
  {{end}}
  <main class="container">
    {{template "content" .}}
  </main>
  <script src="/static/app.js" defer></script>
  {{block "page_scripts" .}}{{end}}
</body>
</html>
{{end}}

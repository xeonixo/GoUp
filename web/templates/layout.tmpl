{{define "layout"}}
<!doctype html>
<html lang="{{if .UILanguage}}{{.UILanguage}}{{else}}en{{end}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
  <link rel="stylesheet" href="/static/style.css">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="manifest" href="/site.webmanifest">
</head>
<body>
  {{if not .HideTopbar}}
  <header class="topbar">
    <div class="topbar-main">
      <a class="brand" href="{{if .AppBase}}{{.AppBase}}{{else}}/{{end}}">
        <img class="brand-logo" src="/assets/logo_goup.svg" alt="GoUp Logo">
      </a>
      {{if .ControlPlaneAdmin}}
      <span class="subtitle">{{index $.Translations "layout.control_plane"}}</span>
      {{else if and .User .User.TenantSlug}}
      <span class="subtitle">{{index $.Translations "layout.tenant_prefix"}} {{if .User.TenantName}}{{.User.TenantName}}{{else}}{{.User.TenantSlug}}{{end}}</span>
      {{end}}
    </div>
    <button class="topbar-hamburger" id="topbar-hamburger" type="button" aria-label="{{index $.Translations "layout.menu_open_aria"}}" data-menu-open-label="{{index $.Translations "layout.menu_open_aria"}}" data-menu-close-label="{{index $.Translations "layout.menu_close_aria"}}" aria-expanded="false" aria-controls="topbar-collapsible">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
    <div class="topbar-collapsible" id="topbar-collapsible">
      {{block "topbar_actions" .}}{{end}}
      <nav class="topbar-nav">
        {{if .ControlPlaneAdmin}}
        <span class="user-pill">{{index $.Translations "layout.admin_access"}}</span>
        <a class="button button-secondary topbar-icon-link" href="/admin/security" aria-label="{{index $.Translations "admin.security.title"}}" title="{{index $.Translations "admin.security.title"}}">
          <span aria-hidden="true">⚙️</span>
          <span class="sr-only">{{index $.Translations "admin.security.title"}}</span>
        </a>
        <a class="button button-secondary topbar-icon-link" href="/admin/access?logout=1" aria-label="{{index $.Translations "layout.logout_aria"}}" title="{{index $.Translations "layout.logout_title"}}">
          <span aria-hidden="true">⎋</span>
          <span class="sr-only">{{index $.Translations "layout.logout_title"}}</span>
        </a>
        {{else if .User}}
        <span class="user-pill">{{if .User.Name}}{{.User.Name}}{{else}}{{.User.Email}}{{end}}</span>
        <a class="button button-secondary topbar-icon-link" href="{{.AppBase}}settings/profile" aria-label="{{index $.Translations "layout.settings_aria"}}" title="{{index $.Translations "layout.settings_title"}}">
          <span aria-hidden="true">⚙️</span>
          <span class="sr-only">{{index $.Translations "layout.settings_title"}}</span>
        </a>
        <a class="button button-secondary topbar-icon-link" href="{{if .AppBase}}{{.AppBase}}auth/logout{{else}}/auth/logout{{end}}" aria-label="{{index $.Translations "layout.logout_aria"}}" title="{{index $.Translations "layout.logout_title"}}">
          <span aria-hidden="true">⎋</span>
          <span class="sr-only">{{index $.Translations "layout.logout_title"}}</span>
        </a>
        {{end}}
      </nav>
    </div>
  </header>
  {{end}}
  <main class="container">
    {{template "content" .}}
  </main>
  <script src="/static/app.js" defer></script>
  {{block "page_scripts" .}}{{end}}
</body>
</html>
{{end}}

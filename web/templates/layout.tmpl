{{define "layout"}}
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <header class="topbar">
    <div class="topbar-main">
      <a class="brand" href="{{if .AppBase}}{{.AppBase}}{{else}}/{{end}}">GoUp</a>
      {{if .ControlPlaneAdmin}}
      <span class="subtitle">Control Plane</span>
      {{else if and .User .User.TenantSlug}}
      <span class="subtitle">Tenant: {{if .User.TenantName}}{{.User.TenantName}}{{else}}{{.User.TenantSlug}}{{end}}</span>
      {{end}}
    </div>
    {{block "topbar_actions" .}}{{end}}
    <nav class="topbar-nav">
      {{if .ControlPlaneAdmin}}
      <span class="user-pill">Admin Access</span>
      <a class="button button-secondary topbar-icon-link" href="/admin/security" aria-label="Control-Plane Sicherheit" title="Control-Plane Sicherheit">
        <span aria-hidden="true">⚙️</span>
        <span class="sr-only">Control-Plane Sicherheit</span>
      </a>
      <a class="button button-secondary topbar-icon-link" href="/admin/access?logout=1" aria-label="Control-Plane Logout" title="Control-Plane Logout">
        <span aria-hidden="true">⎋</span>
        <span class="sr-only">Control-Plane Logout</span>
      </a>
      {{else if .User}}
      <span class="user-pill">{{if .User.Name}}{{.User.Name}}{{else}}{{.User.Email}}{{end}}</span>
      <a class="button button-secondary topbar-icon-link" href="{{.AppBase}}settings/profile" aria-label="Settings" title="Settings">
        <span aria-hidden="true">⚙️</span>
        <span class="sr-only">Settings</span>
      </a>
      <a class="button button-secondary topbar-icon-link" href="/auth/logout" aria-label="Logout" title="Logout">
        <span aria-hidden="true">⎋</span>
        <span class="sr-only">Logout</span>
      </a>
      {{end}}
    </nav>
  </header>
  <main class="container">
    {{template "content" .}}
  </main>
  <script src="/static/app.js" defer></script>
  {{block "page_scripts" .}}{{end}}
</body>
</html>
{{end}}

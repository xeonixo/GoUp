{{define "layout"}}
<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{.Title}}</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <header class="topbar">
    <div>
      <a class="brand" href="{{if .AppBase}}{{.AppBase}}{{else}}/{{end}}">GoUp</a>
      <span class="subtitle">leichtes Uptime-Monitoring{{if and .User .User.TenantSlug}} · Tenant: {{if .User.TenantName}}{{.User.TenantName}}{{else}}{{.User.TenantSlug}}{{end}}{{end}}</span>
    </div>
    <nav>
      {{if .User}}
      <span class="user-pill">{{if .User.Name}}{{.User.Name}}{{else}}{{.User.Email}}{{end}}</span>
      {{if or .User.SuperAdmin (eq .User.Role "admin")}}
      <a class="button button-secondary" href="{{.AppBase}}settings/users">Settings</a>
      {{end}}
      <a class="button button-secondary" href="/auth/logout">Logout</a>
      {{end}}
    </nav>
  </header>
  <main class="container">
    {{template "content" .}}
  </main>
  <script>
    (function () {
      var scrollKey = "goup:scroll:" + window.location.pathname;

      window.addEventListener("beforeunload", function () {
        try {
          sessionStorage.setItem(scrollKey, String(window.scrollY || 0));
        } catch (_) {}
      });

      window.addEventListener("DOMContentLoaded", function () {
        try {
          var currentURL = new URL(window.location.href);
          var changed = false;
          if (currentURL.searchParams.has("error")) {
            currentURL.searchParams.delete("error");
            changed = true;
          }
          if (currentURL.searchParams.has("notice")) {
            currentURL.searchParams.delete("notice");
            changed = true;
          }
          if (changed) {
            var next = currentURL.pathname;
            var qs = currentURL.searchParams.toString();
            if (qs) {
              next += "?" + qs;
            }
            if (currentURL.hash) {
              next += currentURL.hash;
            }
            history.replaceState({}, "", next);
          }
        } catch (_) {}

        try {
          if (!window.location.hash) {
            var y = parseInt(sessionStorage.getItem(scrollKey) || "0", 10);
            if (!isNaN(y) && y > 0) {
              window.scrollTo({ top: y, behavior: "auto" });
            }
          }
        } catch (_) {}

        var nodes = document.querySelectorAll(".js-local-datetime[data-utc]");
        for (var i = 0; i < nodes.length; i++) {
          var el = nodes[i];
          var raw = el.getAttribute("data-utc");
          if (!raw) continue;
          var d = new Date(raw);
          if (isNaN(d.getTime())) continue;
          el.textContent = d.toLocaleString();
          el.title = raw;
        }
      });
    })();
  </script>
</body>
</html>
{{end}}

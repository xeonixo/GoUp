{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="{{$.AppBase}}" class="admin-nav-link">{{index $.Translations "settings.nav.dashboard"}}</a>
    <a href="{{$.AppBase}}settings/profile" class="admin-nav-link">{{index $.Translations "settings.nav.profile"}}</a>
    <a href="{{$.AppBase}}settings/users" class="admin-nav-link is-active">{{index $.Translations "settings.nav.users"}}</a>
    <a href="{{$.AppBase}}settings/providers" class="admin-nav-link">{{index $.Translations "settings.nav.oidc_providers"}}</a>
    <a href="{{$.AppBase}}settings/remote-nodes" class="admin-nav-link">{{index $.Translations "settings.nav.remote_nodes"}}</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>{{index $.Translations "settings.users.title"}}</h1>
    </div>
    <div class="admin-actions-inline">
      <a href="{{$.AppBase}}settings/local-users/new" class="button">{{index $.Translations "settings.users.new_button"}}</a>
    </div>
  </div>

  <div class="card table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>{{index $.Translations "settings.users.table_login"}}</th>
          <th>{{index $.Translations "settings.users.table_type"}}</th>
          <th>{{index $.Translations "settings.users.table_name"}}</th>
          <th>{{index $.Translations "settings.users.table_email"}}</th>
          <th>{{index $.Translations "settings.users.table_role"}}</th>
          <th>{{index $.Translations "settings.users.last_login"}}</th>
          <th>{{index $.Translations "settings.users.table_actions"}}</th>
        </tr>
      </thead>
      <tbody>
        {{if .AdminTenantUsers}}
        {{range .AdminTenantUsers}}
        <tr>
          <td>{{if .LoginName}}{{.LoginName}}{{else}}—{{end}}{{if eq $.User.UserID .UserID}} <span class="muted">({{index $.Translations "settings.users.you"}})</span>{{end}}</td>
          <td>
            {{if .HasLocalCredentials}}<span class="status-badge">LOCAL</span>{{end}}
            {{if .HasOIDCIdentity}}<span class="status-badge">OIDC</span>{{end}}
            {{if and (not .HasLocalCredentials) (not .HasOIDCIdentity)}}<span class="status-badge status-badge-muted">UNK</span>{{end}}
          </td>
          <td>{{.DisplayName}}</td>
          <td>{{.Email}}</td>
          <td>
            <form method="POST" action="{{$.AppBase}}settings/users/{{.UserID}}/role" class="admin-actions-inline">
              <select name="role">
                <option value="viewer" {{if eq .Role "viewer"}}selected{{end}}>viewer</option>
                <option value="admin" {{if eq .Role "admin"}}selected{{end}}>admin</option>
              </select>
              <button type="submit" class="button button-secondary button-small">{{index $.Translations "common.save"}}</button>
            </form>
          </td>
          <td>{{if .LastLoginAt}}<span class="js-local-datetime" data-utc="{{.LastLoginAt.Format "2006-01-02T15:04:05Z07:00"}}">{{.LastLoginAt}}</span>{{else}}—{{end}}</td>
          <td class="admin-actions-inline">
            {{if .HasLocalCredentials}}
            <a href="{{$.AppBase}}settings/local-users/{{.UserID}}/edit" class="button button-secondary button-small">{{index $.Translations "settings.users.edit_local_button"}}</a>
            <form method="POST" action="{{$.AppBase}}settings/local-users/{{.UserID}}/delete" class="inline-form" data-confirm="{{index $.Translations "settings.users.delete_local_confirm"}}">
              <button type="submit" class="button button-danger button-small">{{index $.Translations "settings.users.delete_local_button"}}</button>
            </form>
            {{end}}
            {{if ne $.User.UserID .UserID}}
            <form method="POST" action="{{$.AppBase}}settings/users/{{.UserID}}/remove" class="inline-form" data-confirm="{{index $.Translations "settings.users.remove_confirm"}}">
              <button type="submit" class="button button-danger button-small">{{index $.Translations "common.remove"}}</button>
            </form>
            {{else}}
            <span class="muted">{{index $.Translations "settings.users.not_possible"}}</span>
            {{end}}
          </td>
        </tr>
        {{end}}
        {{else}}
        <tr>
          <td colspan="7" class="muted">{{index $.Translations "settings.users.no_users"}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}

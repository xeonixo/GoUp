{{define "content"}}
<section class="stack">
  <article class="card stack">
    <div>
      <h1>{{index $.Translations "admin.security.title"}}</h1>
      <p class="muted">{{index $.Translations "admin.security.username_label"}}: <strong>{{.AdminUsername}}</strong></p>
      <p class="muted">{{index $.Translations "admin.security.totp_status_label"}}: {{if .TOTPEnabled}}{{index $.Translations "admin.security.enabled"}}{{else}}{{index $.Translations "admin.security.disabled"}}{{end}}</p>
    </div>

    {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}
    {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}

    <form method="POST" action="/admin/security" class="stack login-form">
      <label for="current_password">{{index $.Translations "admin.security.current_password_required_label"}}</label>
      <input id="current_password" name="current_password" type="password" required autocomplete="current-password">

      <label for="new_password">{{index $.Translations "admin.security.new_password_optional_label"}}</label>
      <input id="new_password" name="new_password" type="password" minlength="12" autocomplete="new-password">

      <label for="new_password_confirm">{{index $.Translations "admin.security.password_confirm_label"}}</label>
      <input id="new_password_confirm" name="new_password_confirm" type="password" minlength="12" autocomplete="new-password">

      <label class="checkbox-row">
        <input type="checkbox" name="enable_totp">
        <span>{{index $.Translations "admin.security.enable_new_totp_checkbox"}}</span>
      </label>

      <label for="totp_secret">{{index $.Translations "admin.security.new_totp_secret_label"}}</label>
      <input id="totp_secret" name="totp_secret" type="text" value="{{.TOTPSecret}}">

      <label for="totp_uri">{{index $.Translations "admin.security.new_totp_uri_label"}}</label>
      <input id="totp_uri" type="text" value="{{.TOTPProvisioningURI}}" readonly>

      <label for="totp_code">{{index $.Translations "admin.security.totp_activation_code_label"}}</label>
      <input id="totp_code" name="totp_code" type="text" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code">

      <button type="submit" class="button">{{index $.Translations "admin.security.save_button"}}</button>
    </form>

    {{if .TOTPEnabled}}
    <form method="POST" action="/admin/security/totp/disable" class="stack login-form">
      <label for="disable_current_password">{{index $.Translations "admin.security.disable_totp_current_password_label"}}</label>
      <input id="disable_current_password" name="current_password" type="password" required autocomplete="current-password">
      <button type="submit" class="button button-secondary">{{index $.Translations "admin.security.totp_disable_button"}}</button>
    </form>
    {{end}}
  </article>
</section>
{{end}}

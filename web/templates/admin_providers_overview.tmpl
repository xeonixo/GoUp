{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">{{index $.Translations "admin.nav.general"}}</a>
    <a href="/admin/tenants" class="admin-nav-link">{{index $.Translations "admin.nav.tenants"}}</a>
    <a href="/admin/providers" class="admin-nav-link is-active">{{index $.Translations "admin.nav.providers"}}</a>
    <a href="/admin/users" class="admin-nav-link">{{index $.Translations "admin.nav.users"}}</a>
    <a href="/admin/remote-nodes" class="admin-nav-link">{{index $.Translations "admin.nav.remote_nodes"}}</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>{{index $.Translations "admin.providers.title"}}</h1>
    </div>
  </div>

  <div class="card table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>{{index $.Translations "admin.users.tenant"}}</th>
          <th>{{index $.Translations "admin.providers.provider_key"}}</th>
          <th>{{index $.Translations "admin.providers.type_label"}}</th>
          <th>{{index $.Translations "admin.providers.name_label"}}</th>
          <th>{{index $.Translations "common.status"}}</th>
          <th>{{index $.Translations "common.actions"}}</th>
        </tr>
      </thead>
      <tbody>
        {{if .AdminProviderRows}}
        {{range .AdminProviderRows}}
        <tr>
          <td>{{.TenantName}}</td>
          <td>{{.ProviderKey}}</td>
          <td><span class="status-badge">{{.Kind}}</span></td>
          <td>{{.DisplayName}}</td>
          <td>{{if .Enabled}}<span class="status-badge status-badge-success">{{index $.Translations "common.active"}}</span>{{else}}<span class="status-badge status-badge-muted">{{index $.Translations "common.inactive"}}</span>{{end}}</td>
          <td class="admin-actions-inline">
            <a href="/admin/tenants/{{.TenantID}}/providers" class="button button-secondary button-small">{{index $.Translations "admin.users.open_tenant"}}</a>
          </td>
        </tr>
        {{end}}
        {{else}}
        <tr>
          <td colspan="6" class="muted">{{index $.Translations "admin.providers.no_providers"}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}

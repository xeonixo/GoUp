{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">Allgemein</a>
    <a href="/admin/tenants" class="admin-nav-link">Tenants</a>
    <a href="/admin/providers" class="admin-nav-link is-active">OCID-Provider</a>
    <a href="/admin/users" class="admin-nav-link">Benutzerverwaltung</a>
    <a href="/admin/remote-nodes" class="admin-nav-link">Remote Nodes</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>OCID-Provider</h1>
    </div>
  </div>

  <div class="card table-card">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Tenant</th>
          <th>Provider Key</th>
          <th>Typ</th>
          <th>Name</th>
          <th>Status</th>
          <th>Aktionen</th>
        </tr>
      </thead>
      <tbody>
        {{if .AdminProviderRows}}
        {{range .AdminProviderRows}}
        <tr>
          <td>{{.TenantName}}</td>
          <td>{{.ProviderKey}}</td>
          <td><span class="status-badge">{{.Kind}}</span></td>
          <td>{{.DisplayName}}</td>
          <td>{{if .Enabled}}<span class="status-badge status-badge-success">Aktiv</span>{{else}}<span class="status-badge status-badge-muted">Deaktiviert</span>{{end}}</td>
          <td class="admin-actions-inline">
            <a href="/admin/tenants/{{.TenantID}}/providers" class="button button-secondary button-small">Tenant öffnen</a>
          </td>
        </tr>
        {{end}}
        {{else}}
        <tr>
          <td colspan="6" class="muted">Keine Provider vorhanden.</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
</div>
{{end}}

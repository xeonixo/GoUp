{{define "content"}}
<section class="card stack narrow">
  <h1>{{index $.Translations "password_reset.confirm.title"}}</h1>
  <p>Tenant: <strong>{{.TenantName}}</strong></p>

  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}
  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}

  <form method="POST" action="/{{.TenantSlug}}/password-reset/confirm" class="stack">
    <input type="hidden" name="token" value="{{.ResetToken}}">
    <label for="password">{{index $.Translations "password_reset.confirm.password_label"}}</label>
    <input id="password" name="password" type="password" required minlength="8" autocomplete="new-password">

    <label for="password_confirm">{{index $.Translations "password_reset.confirm.password_confirm_label"}}</label>
    <input id="password_confirm" name="password_confirm" type="password" required minlength="8" autocomplete="new-password">

    <button type="submit" class="button">{{index $.Translations "password_reset.confirm.submit_button"}}</button>
    <a href="/{{.TenantSlug}}/login" class="button button-secondary">{{index $.Translations "common.cancel"}}</a>
  </form>
</section>
{{end}}

{{define "topbar_actions"}}
<div class="topbar-dashboard-actions">
  <div class="trend-range-toggle topbar-trend-range" role="tablist" aria-label="Trend-Zeitraum">
  {{range .TrendRanges}}
  <a href="{{$.AppBase}}?trend={{.Value}}" class="button button-small {{if not .Selected}}button-secondary{{end}}" {{if .Selected}}aria-current="page"{{end}}>{{.Label}}</a>
  {{end}}
  </div>
  {{if .IsAdmin}}<button class="button" type="button" id="open-create-monitor">+ Monitor</button>{{end}}
</div>
{{end}}

{{define "content"}}
{{if .Notice}}
<section class="notice success">{{.Notice}}</section>
{{end}}
{{if .Error}}
<section class="notice error">{{.Error}}</section>
{{end}}

<div id="dashboard-page" data-app-base="{{$.AppBase}}" data-trend-value="{{.TrendValue}}" data-state-owner="{{if .User}}{{if .User.Email}}{{.User.Email}}{{else}}{{.User.Name}}{{end}}{{end}}" data-is-admin="{{if .IsAdmin}}1{{else}}0{{end}}">

<section id="dashboard-live-stats" class="stats-grid stats-grid-wide">
  <article class="card stat-card stat-card-primary">
    <h2>Monitore</h2>
    <div class="metric">{{.Stats.MonitorCount}}</div>
  </article>
  <article class="card stat-card">
    <h2>Aktiv</h2>
    <div class="metric">{{.Stats.EnabledMonitorCount}}</div>
  </article>
  <article class="card stat-card {{if gt .Stats.OpenIncidentCount 0}}stat-card-incident{{end}}">
    <h2>Offene Incidents</h2>
    <div class="metric {{if gt .Stats.OpenIncidentCount 0}}metric-danger{{end}}">{{.Stats.OpenIncidentCount}}</div>
  </article>
</section>

{{if .IsAdmin}}
<dialog id="monitor-modal" class="monitor-modal">
  <form method="post" action="{{$.AppBase}}monitors/save" class="stack form-grid" id="monitor-form">
    <input type="hidden" name="id" id="monitor-id">
    <h2 id="monitor-modal-title">Monitor anlegen</h2>

    <label>
      <span>Typ</span>
      <select name="kind" id="monitor-kind">
        <option value="https">HTTPS</option>
        <option value="tcp">TCP</option>
        <option value="icmp">ICMP</option>
        <option value="smtp">SMTP</option>
        <option value="imap">IMAP</option>
        <option value="dns">DNS</option>
        <option value="udp">UDP</option>
        <option value="whois">WHOIS (Domain-Ablauf)</option>
      </select>
    </label>

    <label id="tls-mode-row">
      <span>TLS-Modus</span>
      <select name="tls_mode" id="monitor-tls-mode">
        <option value="tls">TLS</option>
        <option value="starttls">STARTTLS</option>
        <option value="none">Kein TLS</option>
      </select>
    </label>

    <label id="https-mode-row" class="checkbox-row" hidden>
      <input type="checkbox" id="monitor-use-https" checked>
      <span id="monitor-use-https-label">HTTPS verwenden</span>
    </label>

    <label id="https-verify-row" class="checkbox-row" hidden>
      <input type="checkbox" id="monitor-verify-cert" checked>
      <span id="monitor-verify-cert-label">Zertifikat prüfen</span>
    </label>

    <label>
      <span>Name</span>
      <input type="text" name="name" id="monitor-name" placeholder="Produktiv-Website" required>
    </label>

    <label>
      <span>Gruppe</span>
      <input type="text" name="group" id="monitor-group" list="monitor-group-options" placeholder="z. B. Mailcow, Nextcloud oder Core">
    </label>

    <datalist id="monitor-group-options">
      {{range .AvailableGroups}}
      <option value="{{.}}"></option>
      {{end}}
    </datalist>

    <label>
      <span>Ziel</span>
      <input type="text" name="target" id="monitor-target" placeholder="example.com/health" required>
      <small class="muted compact" id="monitor-target-hint">Für HTTP(S): Host/Pfad ohne Protokoll (wird automatisch ergänzt).</small>
    </label>

    <div class="inline-grid">
      <label>
        <span>Intervall (Sekunden)</span>
        <input type="number" name="interval_seconds" id="monitor-interval" min="15" value="60" required>
      </label>
      <label>
        <span>Timeout (Sekunden)</span>
        <input type="number" name="timeout_seconds" id="monitor-timeout" min="1" value="10" required>
      </label>
    </div>

    <label id="expected-status-row" hidden>
      <span>Erwarteter HTTP-Status (optional)</span>
      <input type="number" name="expected_status_code" id="monitor-expected-status" min="100" max="599" placeholder="200">
    </label>

    <label id="expected-text-row" hidden>
      <span>Erwartete Keywords (optional)</span>
      <input type="text" name="expected_text" id="monitor-expected-text" placeholder="z. B. healthy, ok">
      <small class="muted compact">Mehrere Keywords mit Komma trennen. Alle Keywords müssen im Body vorkommen.</small>
    </label>

    <label class="checkbox-row">
      <input type="checkbox" name="enabled" id="monitor-enabled" checked>
      <span>Monitor aktiv</span>
    </label>

    <label class="checkbox-row">
      <input type="checkbox" name="notify_on_recovery" id="monitor-notify" checked>
      <span>Recovery-Benachrichtigung senden</span>
    </label>

    <div class="modal-actions">
      <button class="button button-secondary" type="button" id="monitor-cancel">Abbrechen</button>
      <button class="button" type="submit">Speichern</button>
    </div>
  </form>
</dialog>
{{end}}

{{if .IsAdmin}}
<dialog id="group-modal" class="monitor-modal group-modal">
  <form method="post" action="{{$.AppBase}}groups/save" class="stack" id="group-form" enctype="multipart/form-data">
    <input type="hidden" name="group" id="group-name-field">
    <input type="hidden" name="trend" value="{{.TrendValue}}">
    <input type="hidden" name="icon_slug" id="group-icon-slug">

    <div class="modal-header">
      <div>
        <h2 id="group-modal-title">Gruppe konfigurieren</h2>
        <p class="muted compact">Wähle ein wiederverwendetes Icon, suche in Dashboard Icons oder lade ein eigenes Icon hoch.</p>
      </div>
      <button class="button button-secondary button-small" type="button" id="group-cancel">Schließen</button>
    </div>

    <div class="group-icon-preview-panel">
      <div class="group-icon-preview-frame" id="group-icon-preview-frame" hidden>
        <img id="group-icon-preview" alt="Gruppen-Icon Vorschau">
      </div>
      <p class="muted compact">Quelle: lokal gecachte Dashboard Icons oder eigener Upload</p>
    </div>

    <label>
      <span>Dashboard Icons durchsuchen</span>
      <input type="search" id="group-icon-search" placeholder="z. B. mailcow, nextcloud, postgres" autocomplete="off" spellcheck="false">
    </label>

    <p class="muted compact" id="group-icon-search-status">Suche nach Namen, Aliasen oder Kategorien.</p>
    <div class="group-icon-results" id="group-icon-results" aria-live="polite"></div>

    <label>
      <span>Eigenes Icon hochladen</span>
      <input type="file" id="group-icon-upload" name="icon_upload" accept=".svg,image/svg+xml,.png,image/png,.webp,image/webp,.jpg,.jpeg,image/jpeg,.ico,image/x-icon,image/vnd.microsoft.icon">
    </label>
    <p class="muted compact">Unterstützt SVG, PNG, WEBP, JPG und ICO. Bereits hochgeladene Dateien werden wiederverwendet.</p>

    <label>
      <span>Eigener Dashboardicons-Slug</span>
      <input type="text" id="group-icon-custom" placeholder="z. B. mailcow oder nextcloud">
    </label>

    <p class="muted compact" id="group-icon-selection">Kein Icon ausgewählt.</p>

    <div class="modal-actions">
      <button class="button button-secondary" type="button" id="group-reset-icon">Icon entfernen</button>
      <button class="button" type="submit">Speichern</button>
    </div>
  </form>
</dialog>
{{end}}

<dialog id="trend-detail-modal" class="monitor-modal trend-detail-modal">
  <div class="stack">
    <div class="modal-header">
      <div>
        <h2 id="trend-detail-title">Trenddetails</h2>
        <p class="muted compact" id="trend-detail-subtitle">Historie</p>
      </div>
      <button class="button button-secondary button-small" type="button" id="trend-detail-close">Schließen</button>
    </div>

    <div class="trend-detail-meta">
      <article class="card trend-detail-card">
        <span class="muted">Status</span>
        <strong id="trend-detail-status">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">Uptime</span>
        <strong id="trend-detail-uptime">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">Letzter Lauf</span>
        <strong id="trend-detail-last-check">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">Ø / Min / Max</span>
        <strong id="trend-detail-latency">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">Checks</span>
        <strong id="trend-detail-checks">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">Ziel</span>
        <strong id="trend-detail-target">—</strong>
      </article>
    </div>

    <section class="card stack">
      <h3 id="trend-detail-range-title">Verlauf</h3>
      <div id="trend-detail-bars" class="trend-bars trend-bars-large"></div>
    </section>

    <section class="card stack">
      <h3>Historie</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Zeitraum</th>
              <th>Ergebnis</th>
            </tr>
          </thead>
          <tbody id="trend-detail-history"></tbody>
        </table>
      </div>
    </section>
  </div>
</dialog>

<section id="dashboard-live-board" class="card stack dashboard-board">
  {{range .MonitorGroups}}
  <section class="monitor-group {{.AccentClass}} stack">
    {{if .Monitors}}
      <div class="service-group-list">
        {{range .Services}}
        {{$serviceTitle := .Title}}
        <details class="service-cluster" {{if .Open}}open{{end}} {{if $.IsAdmin}}draggable="true"{{end}} data-group="{{.Title}}">
          <summary class="service-cluster-header">
            <div class="service-summary">
              <div class="service-summary-top">
                <div class="service-cluster-title">
                  {{if .IconURL}}
                  <img class="group-icon" src="{{.IconURL}}" alt="{{.Title}} Icon" loading="lazy" referrerpolicy="no-referrer">
                  {{end}}
                  <div>
                    <h4>{{.Title}}</h4>
                  </div>
                </div>
                <div class="service-summary-right">
                  <span class="service-count" aria-label="{{len .Monitors}} Monitore">{{len .Monitors}}</span>
                  <span class="status-pill {{.StatusClass}}">{{.StatusLabel}}</span>
                  {{if $.IsAdmin}}
                  <details class="action-menu">
                  <summary class="action-menu-trigger" aria-label="Aktionen für Gruppe {{.Title}}">⋯</summary>
                  <div class="action-menu-list">
                    <button
                      class="action-menu-item group-settings"
                      type="button"
                      data-group="{{.Title}}"
                      data-icon-slug="{{.IconSlug}}"
                      aria-label="Gruppen-Icon für {{.Title}} konfigurieren">Icon bearbeiten</button>
                    <form method="post" action="{{$.AppBase}}groups/delete" class="action-menu-form" data-confirm="Gruppe inklusive aller Monitore wirklich löschen?">
                      <input type="hidden" name="group" value="{{.Title}}">
                      <button class="action-menu-item action-menu-item-danger" type="submit">Gruppe löschen</button>
                    </form>
                  </div>
                </details>
                  {{end}}
                </div>
              </div>
              {{if .TrendPoints}}
              <button
                class="trend-trigger service-summary-trend"
                type="button"
                data-monitor-name="Dienstgruppe: {{.Title}}"
                data-monitor-kind="Service"
                data-target="{{.Title}}"
                data-status="{{.StatusLabel}}"
                data-uptime="{{.UptimeLabel}}"
                data-trend-label="{{.TrendLabel}}"
                data-last-check=""
                data-last-message="{{.StatusInfo}}"
                aria-label="Trenddetails für Dienstgruppe {{.Title}} öffnen">
                <div class="trend-bars" aria-label="Trend {{.TrendLabel}}">
                  {{range .TrendPoints}}
                  <span class="trend-bar {{.Class}}" data-bucket="{{.BucketRaw}}" data-label="{{.Label}}" data-format="{{.Format}}" data-checks="{{.Checks}}" data-avg-ms="{{.AvgMS}}" data-min-ms="{{.MinMS}}" data-max-ms="{{.MaxMS}}"></span>
                  {{end}}
                </div>
              </button>
              {{else}}
              <p class="muted compact">Keine Monitore in dieser Gruppe.</p>
              {{end}}
            </div>
          </summary>
          <div class="monitor-grid">
      {{range .Monitors}}
      <article class="card monitor-card {{.StatusClass}}" {{if $.IsAdmin}}draggable="true"{{end}} data-monitor-id="{{.ID}}" data-group="{{$serviceTitle}}" data-interval-seconds="{{.IntervalSeconds}}" data-last-check="{{.LastCheckedAtRaw}}">
        <div class="monitor-card-header">
          <div>
              <h5>{{.Name}}</h5>
            <p class="muted compact">{{.Kind}}{{if .TLSMode}} / {{.TLSMode}}{{end}} · alle {{.Interval}} · Timeout {{.Timeout}}</p>
          </div>
          <div class="monitor-header-right">
            {{if $.IsAdmin}}
            <button
              class="monitor-cycle-indicator monitor-cycle-trigger"
              type="button"
              data-check-monitor-id="{{.ID}}"
              aria-label="Monitor {{.Name}} jetzt prüfen"
              title="Monitor jetzt prüfen"></button>
            {{else}}
            <span class="monitor-cycle-indicator" aria-hidden="true"></span>
            {{end}}
            <span class="status-pill {{.StatusClass}}">{{.StatusLabel}}</span>
            {{if $.IsAdmin}}
            <details class="action-menu">
              <summary class="action-menu-trigger" aria-label="Aktionen für Monitor {{.Name}}">⋯</summary>
              <div class="action-menu-list">
                <button
                  class="action-menu-item edit-monitor"
                  type="button"
                  data-id="{{.ID}}"
                  data-name="{{.Name}}"
                  data-group="{{.Group}}"
                  data-kind="{{.KindValue}}"
                  data-tls-mode="{{.TLSModeValue}}"
                  data-target="{{.Target}}"
                  data-interval="{{.IntervalSeconds}}"
                  data-timeout="{{.TimeoutSeconds}}"
                  data-enabled="{{if .Enabled}}1{{else}}0{{end}}"
                  data-notify-on-recovery="{{if .NotifyOnRecovery}}1{{else}}0{{end}}"
                  data-expected-status="{{.ExpectedStatus}}"
                  data-expected-text="{{.ExpectedText}}">
                  Bearbeiten
                </button>
                <form method="post" action="{{$.AppBase}}monitors/enabled" class="action-menu-form">
                  <input type="hidden" name="id" value="{{.ID}}">
                  <input type="hidden" name="enabled" value="{{if .Enabled}}0{{else}}1{{end}}">
                  <button class="action-menu-item" type="submit">{{if .Enabled}}Pausieren{{else}}Aktivieren{{end}}</button>
                </form>
                <form method="post" action="{{$.AppBase}}monitors/delete" class="action-menu-form" data-confirm="Monitor wirklich löschen?">
                  <input type="hidden" name="id" value="{{.ID}}">
                  <button class="action-menu-item action-menu-item-danger" type="submit">Löschen</button>
                </form>
              </div>
            </details>
            {{end}}
          </div>
        </div>

        <button
          class="trend-trigger monitor-summary-trend"
          type="button"
          data-monitor-name="{{.Name}}"
          data-monitor-kind="{{.Kind}}"
          data-target="{{.TargetLabel}}"
          data-status="{{.StatusLabel}}"
          data-uptime="{{.UptimeLabel}}"
          data-trend-label="{{.TrendLabel}}"
          data-last-check="{{.LastCheckedAtRaw}}"
          data-last-message="{{.LastMessage}}"
          aria-label="Trenddetails für {{.Name}} öffnen">
          <div class="trend-bars" aria-label="Trend {{.TrendLabel}}">
            {{range .TrendPoints}}
            <span class="trend-bar {{.Class}}" data-bucket="{{.BucketRaw}}" data-label="{{.Label}}" data-format="{{.Format}}" data-checks="{{.Checks}}" data-avg-ms="{{.AvgMS}}" data-min-ms="{{.MinMS}}" data-max-ms="{{.MaxMS}}"></span>
            {{end}}
          </div>
        </button>

        <div class="monitor-card-body stack compact-stack">
          <div class="info-row">
            <span class="muted">Ziel</span>
            <strong class="break-all">{{.TargetLabel}}</strong>
          </div>
          <div class="info-row">
            <span class="muted">Status</span>
            <strong>{{.StatusSummary}}</strong>
          </div>

          <div class="monitor-metrics">
            <div class="monitor-metric">
              <span class="muted">Latenz</span>
              <strong>{{if .LastLatency}}{{.LastLatency}}{{else}}—{{end}}</strong>
            </div>
            {{if eq .KindValue "https"}}
            <div class="monitor-metric">
              <span class="muted">HTTP</span>
              <strong>{{if .HTTPStatusCode}}{{.HTTPStatusCode}}{{else}}—{{end}}</strong>
            </div>
            {{end}}
            <div class="monitor-metric">
              <span class="muted">Letzter Lauf</span>
              <strong>{{if .LastCheckedAtRaw}}<time class="client-time" datetime="{{.LastCheckedAtRaw}}" data-format="relative-age">{{.LastCheckedAt}}</time>{{else}}—{{end}}</strong>
            </div>
            {{if eq .KindValue "https" "tcp" "smtp" "imap"}}
            <div class="monitor-metric">
              <span class="muted">Zertifikat</span>
              <strong>{{if .TLSNotAfterRaw}}<time class="client-time" datetime="{{.TLSNotAfterRaw}}" data-format="minute">{{.TLSNotAfter}}</time>{{else}}—{{end}}</strong>
              {{if .TLSDaysRemaining}}<span class="muted compact">{{.TLSDaysRemaining}} verbleibend</span>{{end}}
            </div>
            {{else if eq .KindValue "whois"}}
            <div class="monitor-metric">
              <span class="muted">Domain-Ablauf</span>
              <strong>{{if .TLSNotAfterRaw}}<time class="client-time" datetime="{{.TLSNotAfterRaw}}" data-format="minute">{{.TLSNotAfter}}</time>{{else}}—{{end}}</strong>
              {{if .TLSDaysRemaining}}<span class="muted compact">{{.TLSDaysRemaining}} verbleibend</span>{{end}}
            </div>
            {{end}}
          </div>

        </div>
      </article>
      {{end}}
          </div>
        </details>
        {{end}}
    </div>
    {{else}}
    <p class="muted">{{.EmptyText}}</p>
    {{end}}
  </section>
  {{end}}
</section>

<section id="dashboard-live-state-events" class="card stack notification-events-card">
  <h2>Letzte Statusänderungen</h2>
  {{if .StateEvents}}
  <div class="state-events-toolbar">
    <label>
      <span class="sr-only">Monitor/Details durchsuchen</span>
      <input type="search" id="state-events-search" placeholder="Monitor oder Details filtern…" autocomplete="off" spellcheck="false">
    </label>
    <label>
      <span class="sr-only">Zielstatus filtern</span>
      <select id="state-events-status-filter">
        <option value="all">Alle Zielstatus</option>
        <option value="down">DOWN</option>
        <option value="degraded">DEGRADED</option>
        <option value="up">UP</option>
      </select>
    </label>
    <label class="checkbox-row">
      <input type="checkbox" id="state-events-incidents-only">
      <span>Nur Incidents</span>
    </label>
    <button class="button button-secondary button-small" type="button" id="state-events-export">CSV exportieren</button>
  </div>
  <p class="muted compact" id="state-events-filter-status"></p>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Zeitpunkt</th>
          <th>Monitor</th>
          <th>Von</th>
          <th>Nach</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody id="state-events-body">
        {{range .StateEvents}}
        <tr data-monitor="{{.Monitor}}" data-from="{{.From}}" data-to="{{.To}}" data-message="{{.Message}}" data-when="{{.WhenRaw}}">
          <td><time class="client-time" datetime="{{.WhenRaw}}" data-format="datetime">{{.When}}</time></td>
          <td>{{.Monitor}}</td>
          <td><span class="status-pill {{.FromClass}}">{{.From}}</span></td>
          <td><span class="status-pill {{.ToClass}}">{{.To}}</span></td>
          <td class="break-all">{{.Message}}</td>
        </tr>
        {{end}}
        <tr id="state-events-empty-row" hidden>
          <td colspan="5" class="muted">Keine Statusänderungen für den aktuellen Filter.</td>
        </tr>
      </tbody>
    </table>
  </div>
  {{else}}
  <p class="muted">Noch keine Statusänderungen vorhanden.</p>
  {{end}}
</section>

<section id="dashboard-live-notification-events" class="card stack notification-events-card">
  <h2>Letzte Notification-Events</h2>
  {{if .Events}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Zeitpunkt</th>
          <th>Monitor</th>
          <th>Event</th>
          <th>Endpoint</th>
          <th>Ergebnis</th>
          <th>Fehler</th>
          <th>Zugestellt</th>
        </tr>
      </thead>
      <tbody>
        {{range .Events}}
        <tr>
          <td><time class="client-time" datetime="{{.WhenRaw}}" data-format="datetime">{{.When}}</time></td>
          <td>{{.Monitor}}</td>
          <td>{{.EventType}}</td>
          <td>{{.Endpoint}}</td>
          <td>{{.Result}}</td>
          <td class="break-all">{{.Error}}</td>
          <td>{{if .DeliveredAtRaw}}<time class="client-time" datetime="{{.DeliveredAtRaw}}" data-format="datetime">{{.DeliveredAt}}</time>{{else}}—{{end}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  <p class="muted">Noch keine Notification-Events vorhanden.</p>
  {{end}}
</section>
</div>
{{end}}

{{define "page_scripts"}}
<script src="/static/dashboard.js" defer></script>
{{end}}

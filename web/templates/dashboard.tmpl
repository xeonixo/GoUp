{{define "topbar_actions"}}
<div class="topbar-dashboard-actions">
  <div class="live-connection-indicator is-connecting" id="live-ws-indicator" role="status" aria-live="polite" aria-label="{{index $.Translations "dashboard.live.connecting"}}" title="{{index $.Translations "dashboard.live.connecting"}}">
    <span class="live-connection-dot" aria-hidden="true"></span>
    <span class="live-connection-text">{{index $.Translations "layout.live_indicator"}}</span>
  </div>
  <div class="trend-range-toggle topbar-trend-range" role="tablist" aria-label="{{index $.Translations "dashboard.topbar.trend_range"}}">
  {{range .TrendRanges}}
  <a href="{{$.AppBase}}?trend={{.Value}}" class="button button-small {{if not .Selected}}button-secondary{{end}}" {{if .Selected}}aria-current="page"{{end}}>{{.Label}}</a>
  {{end}}
  </div>
  {{if .IsAdmin}}<button class="button" type="button" id="open-create-monitor">{{index $.Translations "dashboard.topbar.create_monitor"}}</button>{{end}}
</div>
{{end}}

{{define "content"}}
{{if .Notice}}
<section class="notice success">{{.Notice}}</section>
{{end}}
{{if .Error}}
<section class="notice error">{{.Error}}</section>
{{end}}

<div id="dashboard-page" data-app-base="{{$.AppBase}}" data-trend-value="{{.TrendValue}}" data-state-owner="{{if .User}}{{if .User.Email}}{{.User.Email}}{{else}}{{.User.Name}}{{end}}{{end}}" data-is-admin="{{if .IsAdmin}}1{{else}}0{{end}}">

<section id="dashboard-live-stats" class="stats-grid stats-grid-wide">
  <article class="card stat-card stat-card-primary">
    <h2>{{index $.Translations "dashboard.stats.monitors_title"}}</h2>
    <div class="metric">{{.Stats.MonitorCount}}</div>
  </article>
  <article class="card stat-card">
    <h2>{{index $.Translations "dashboard.stats.active_title"}}</h2>
    <div class="metric">{{.Stats.EnabledMonitorCount}}</div>
  </article>
  <article class="card stat-card {{if gt .Stats.OpenIncidentCount 0}}stat-card-incident{{end}}">
    <h2>{{index $.Translations "dashboard.stats.incidents_title"}}</h2>
    <div class="metric {{if gt .Stats.OpenIncidentCount 0}}metric-danger{{end}}">{{.Stats.OpenIncidentCount}}</div>
  </article>
</section>

{{if .IsAdmin}}
<dialog id="monitor-modal" class="monitor-modal">
  <form method="post" action="{{$.AppBase}}monitors/save" class="stack form-grid" id="monitor-form">
    <input type="hidden" name="id" id="monitor-id">
    <div class="modal-header">
      <h2 id="monitor-modal-title" data-create-title="{{index $.Translations "dashboard.modal.create_title"}}" data-edit-title="{{index $.Translations "dashboard.modal.edit_title"}}">{{index $.Translations "dashboard.modal.create_title"}}</h2>
      <button class="modal-close-button" type="button" id="monitor-close" aria-label="{{index $.Translations "dashboard.modal.close_aria"}}">×</button>
    </div>

    <label>
      <span>{{index $.Translations "dashboard.modal.type_label"}}</span>
      <select name="kind" id="monitor-kind">
        <option value="https">{{index $.Translations "dashboard.modal.type_https"}}</option>
        <option value="tcp">{{index $.Translations "dashboard.modal.type_tcp"}}</option>
        <option value="icmp">{{index $.Translations "dashboard.modal.type_icmp"}}</option>
        <option value="smtp">{{index $.Translations "dashboard.modal.type_smtp"}}</option>
        <option value="imap">{{index $.Translations "dashboard.modal.type_imap"}}</option>
        <option value="dns">{{index $.Translations "dashboard.modal.type_dns"}}</option>
        <option value="udp">{{index $.Translations "dashboard.modal.type_udp"}}</option>
        <option value="whois">{{index $.Translations "dashboard.modal.type_whois"}}</option>
      </select>
    </label>

    <label id="tls-mode-row">
      <span>{{index $.Translations "dashboard.modal.tls_mode"}}</span>
      <select name="tls_mode" id="monitor-tls-mode">
        <option value="tls">{{index $.Translations "dashboard.modal.tls_mode_tls"}}</option>
        <option value="starttls">{{index $.Translations "dashboard.modal.tls_mode_starttls"}}</option>
        <option value="none">{{index $.Translations "dashboard.modal.tls_mode_none"}}</option>
      </select>
    </label>

    <label>
      <span>{{index $.Translations "dashboard.modal.name_label"}}</span>
      <input type="text" name="name" id="monitor-name" placeholder="{{index $.Translations "dashboard.modal.name_placeholder"}}" required>
    </label>

    <label>
      <span>{{index $.Translations "dashboard.modal.group_label"}}</span>
      <input type="text" name="group" id="monitor-group" list="monitor-group-options" placeholder="{{index $.Translations "dashboard.modal.group_placeholder"}}">
    </label>

    <datalist id="monitor-group-options">
      {{range .AvailableGroups}}
      <option value="{{.}}"></option>
      {{end}}
    </datalist>

    {{if .HasRemoteNodes}}
    <label id="monitor-executor-row">
      <span>{{index $.Translations "dashboard.modal.executor_label"}}</span>
      <select name="executor" id="monitor-executor">
        {{range .MonitorExecutors}}
        <option value="{{.Value}}">{{.Label}}</option>
        {{end}}
      </select>
      <small class="muted compact">{{index $.Translations "dashboard.modal.executor_hint"}}</small>
    </label>
    {{end}}

    <label id="monitor-target-row">
      <span>{{index $.Translations "dashboard.modal.target_label"}}</span>
      <input type="text" name="target" id="monitor-target" placeholder="{{index $.Translations "dashboard.modal.target_placeholder"}}" required>
      <small class="muted compact" id="monitor-target-hint">{{index $.Translations "dashboard.modal.target_hint_http"}}</small>
      <small class="muted compact" id="monitor-target-warn" hidden>{{index $.Translations "dashboard.modal.target_warn_whois_de"}}</small>
    </label>

    <label id="https-target-row" hidden>
      <span>{{index $.Translations "dashboard.modal.http_target_label"}}</span>
      <div class="inline-grid inline-grid-http-target">
        <label class="field-compact">
          <span>{{index $.Translations "dashboard.modal.protocol_label"}}</span>
          <select id="monitor-http-scheme">
            <option value="https">https://</option>
            <option value="http">http://</option>
          </select>
        </label>
        <label>
          <span>{{index $.Translations "dashboard.modal.host_label"}}</span>
          <input type="text" id="monitor-http-host" name="http_host" placeholder="{{index $.Translations "dashboard.modal.http_host_placeholder"}}" autocomplete="off" spellcheck="false">
        </label>
        <label class="field-compact field-port-compact">
          <span>{{index $.Translations "dashboard.modal.port_optional_label"}}</span>
          <input type="number" id="monitor-http-port" name="http_port" min="1" max="65535" placeholder="{{index $.Translations "dashboard.modal.http_port_placeholder"}}" inputmode="numeric">
        </label>
      </div>
      <label id="https-skip-verify-row" class="checkbox-row" hidden>
        <input type="checkbox" id="monitor-http-skip-cert">
        <span id="monitor-http-skip-cert-label">{{index $.Translations "dashboard.modal.skip_cert_checkbox"}}</span>
      </label>
      <label>
        <span>{{index $.Translations "dashboard.modal.path_query_optional_label"}}</span>
        <input type="text" id="monitor-http-path" name="http_path" placeholder="{{index $.Translations "dashboard.modal.http_path_placeholder"}}">
      </label>
    </label>

    <label id="https-family-row" hidden>
      <span>{{index $.Translations "dashboard.modal.ip_family_hostname_only"}}</span>
      <select id="monitor-https-family" name="https_family">
        <option value="ipv4">IPv4</option>
        <option value="ipv6">IPv6</option>
        <option value="dual" selected>Dual Stack (IPv4 + IPv6)</option>
      </select>
      <small class="muted compact">{{index $.Translations "dashboard.modal.https_family_hint"}}</small>
    </label>

    <label id="tcp-target-row" hidden>
      <span>{{index $.Translations "dashboard.modal.tcp_target_label"}}</span>
      <div class="inline-grid">
        <label>
          <span>{{index $.Translations "dashboard.modal.host_label"}}</span>
          <input type="text" id="monitor-tcp-host" name="tcp_host" placeholder="{{index $.Translations "dashboard.modal.tcp_host_placeholder"}}" autocomplete="off" spellcheck="false">
        </label>
        <label>
          <span>{{index $.Translations "dashboard.modal.port_label"}}</span>
          <input type="number" id="monitor-tcp-port" name="tcp_port" min="1" max="65535" placeholder="{{index $.Translations "dashboard.modal.tcp_port_placeholder"}}" inputmode="numeric">
        </label>
      </div>
    </label>

    <label id="dns-target-row" hidden>
      <span>{{index $.Translations "dashboard.modal.dns_target_label"}}</span>
      <div class="inline-grid">
        <label>
          <span>{{index $.Translations "dashboard.modal.host_label"}}</span>
          <input type="text" id="monitor-dns-host" name="dns_host" placeholder="{{index $.Translations "dashboard.modal.dns_host_placeholder"}}" autocomplete="off" spellcheck="false">
        </label>
        <label class="field-compact">
          <span>{{index $.Translations "dashboard.modal.dns_record_type_label"}}</span>
          <select id="monitor-dns-record-type" name="dns_record_type">
            <option value="mixed">{{index $.Translations "dashboard.modal.dns_record_type_mixed"}}</option>
            <option value="a">{{index $.Translations "dashboard.modal.dns_record_type_a"}}</option>
            <option value="aaaa">{{index $.Translations "dashboard.modal.dns_record_type_aaaa"}}</option>
            <option value="cname">{{index $.Translations "dashboard.modal.dns_record_type_cname"}}</option>
            <option value="mx">{{index $.Translations "dashboard.modal.dns_record_type_mx"}}</option>
            <option value="txt">{{index $.Translations "dashboard.modal.dns_record_type_txt"}}</option>
            <option value="ns">{{index $.Translations "dashboard.modal.dns_record_type_ns"}}</option>
            <option value="srv">{{index $.Translations "dashboard.modal.dns_record_type_srv"}}</option>
            <option value="caa">{{index $.Translations "dashboard.modal.dns_record_type_caa"}}</option>
            <option value="soa">{{index $.Translations "dashboard.modal.dns_record_type_soa"}}</option>
          </select>
        </label>
      </div>
      <label>
        <span>{{index $.Translations "dashboard.modal.dns_server_label"}}</span>
        <input type="text" id="monitor-dns-server" name="dns_server" placeholder="{{index $.Translations "dashboard.modal.dns_server_placeholder"}}" autocomplete="off" spellcheck="false">
      </label>
      <small class="muted compact">{{index $.Translations "dashboard.modal.dns_server_hint"}}</small>
    </label>

    <label id="https-mode-row" class="checkbox-row" hidden>
      <input type="checkbox" id="monitor-use-https" checked>
      <span id="monitor-use-https-label">{{index $.Translations "dashboard.modal.tcp_tls_handshake"}}</span>
    </label>

    <label id="https-verify-row" class="checkbox-row" hidden>
      <input type="checkbox" id="monitor-verify-cert" checked>
      <span id="monitor-verify-cert-label">{{index $.Translations "dashboard.modal.verify_cert_checkbox"}}</span>
    </label>

    <label id="tcp-family-row" hidden>
      <span>{{index $.Translations "dashboard.modal.ip_family_hostname_only"}}</span>
      <select id="monitor-tcp-family" name="tcp_family">
        <option value="ipv4">IPv4</option>
        <option value="ipv6">IPv6</option>
        <option value="dual" selected>Dual Stack (IPv4 + IPv6)</option>
      </select>
      <small class="muted compact">{{index $.Translations "dashboard.modal.tcp_family_hint"}}</small>
    </label>

    <label id="mail-target-row" hidden>
      <span>{{index $.Translations "dashboard.modal.mail_target_label"}}</span>
      <div class="inline-grid">
        <label>
          <span>{{index $.Translations "dashboard.modal.host_label"}}</span>
          <input type="text" id="monitor-mail-host" name="mail_host" placeholder="{{index $.Translations "dashboard.modal.mail_host_placeholder"}}" autocomplete="off" spellcheck="false">
        </label>
        <label>
          <span>{{index $.Translations "dashboard.modal.port_label"}}</span>
          <input type="number" id="monitor-mail-port" name="mail_port" min="1" max="65535" placeholder="{{index $.Translations "dashboard.modal.mail_port_placeholder"}}" inputmode="numeric">
        </label>
      </div>
    </label>

    <label id="mail-family-row" hidden>
      <span>{{index $.Translations "dashboard.modal.ip_family_hostname_only"}}</span>
      <select id="monitor-mail-family" name="mail_family">
        <option value="ipv4">IPv4</option>
        <option value="ipv6">IPv6</option>
        <option value="dual" selected>Dual Stack (IPv4 + IPv6)</option>
      </select>
      <small class="muted compact">{{index $.Translations "dashboard.modal.mail_family_hint"}}</small>
    </label>

    <label id="mail-verify-row" class="checkbox-row" hidden>
      <input type="checkbox" id="monitor-mail-verify-cert" name="mail_skip_cert">
      <span id="monitor-mail-verify-cert-label">{{index $.Translations "dashboard.modal.skip_cert_checkbox"}}</span>
    </label>

    <label id="udp-check-row" hidden>
      <span>{{index $.Translations "dashboard.modal.udp_check_label"}}</span>
      <select id="monitor-udp-check" name="udp_check">
        <option value="dns">{{index $.Translations "dashboard.modal.udp_check_dns"}}</option>
        <option value="ntp">{{index $.Translations "dashboard.modal.udp_check_ntp"}}</option>
      </select>
      <small class="muted compact">{{index $.Translations "dashboard.modal.udp_check_hint"}}</small>
    </label>

    <label id="udp-target-row" hidden>
      <span>{{index $.Translations "dashboard.modal.udp_target_label"}}</span>
      <div class="inline-grid">
        <label>
          <span>{{index $.Translations "dashboard.modal.host_label"}}</span>
          <input type="text" id="monitor-udp-host" name="udp_host" placeholder="{{index $.Translations "dashboard.modal.udp_host_placeholder"}}" autocomplete="off" spellcheck="false">
        </label>
        <label>
          <span>{{index $.Translations "dashboard.modal.port_label"}}</span>
          <input type="number" id="monitor-udp-port" name="udp_port" min="1" max="65535" placeholder="{{index $.Translations "dashboard.modal.udp_port_placeholder"}}" inputmode="numeric">
        </label>
      </div>
      <small class="muted compact">{{index $.Translations "dashboard.modal.udp_target_hint"}}</small>
    </label>

    <label id="udp-family-row" hidden>
      <span>{{index $.Translations "dashboard.modal.ip_family_hostname_only"}}</span>
      <select id="monitor-udp-family" name="udp_family">
        <option value="ipv4">IPv4</option>
        <option value="ipv6">IPv6</option>
        <option value="dual" selected>Dual Stack (IPv4 + IPv6)</option>
      </select>
      <small class="muted compact">{{index $.Translations "dashboard.modal.udp_family_hint"}}</small>
    </label>

    <label id="icmp-family-row" hidden>
      <span>{{index $.Translations "dashboard.modal.ip_family_hostname_only"}}</span>
      <select id="monitor-icmp-family" name="icmp_family">
        <option value="ipv4">IPv4</option>
        <option value="ipv6">IPv6</option>
        <option value="dual">Dual Stack (IPv4 + IPv6)</option>
      </select>
      <small class="muted compact">{{index $.Translations "dashboard.modal.icmp_family_hint"}}</small>
    </label>

    <div class="inline-grid">
      <label>
        <span>{{index $.Translations "dashboard.modal.interval_seconds_label"}}</span>
        <input type="number" name="interval_seconds" id="monitor-interval" min="15" value="60" required>
      </label>
      <label>
        <span>{{index $.Translations "dashboard.modal.timeout_seconds_label"}}</span>
        <input type="number" name="timeout_seconds" id="monitor-timeout" min="1" value="10" required>
      </label>
    </div>

    <label id="expected-status-row" hidden>
      <span>{{index $.Translations "dashboard.modal.expected_http_status_optional"}}</span>
      <input type="number" name="expected_status_code" id="monitor-expected-status" min="100" max="599" placeholder="{{index $.Translations "dashboard.modal.expected_status_placeholder"}}">
    </label>

    <label id="expected-text-row" hidden>
      <span id="monitor-expected-text-label">{{index $.Translations "dashboard.modal.expected_keywords_optional"}}</span>
      <input type="text" name="expected_text" id="monitor-expected-text" placeholder="{{index $.Translations "dashboard.modal.expected_text_placeholder"}}">
      <small class="muted compact" id="monitor-expected-text-hint">{{index $.Translations "dashboard.modal.expected_keywords_hint"}}</small>
    </label>

    <label class="checkbox-row">
      <input type="checkbox" name="enabled" id="monitor-enabled" checked>
      <span>{{index $.Translations "dashboard.modal.enabled_checkbox"}}</span>
    </label>

    <label class="checkbox-row">
      <input type="checkbox" name="notify_on_recovery" id="monitor-notify" checked>
      <span>{{index $.Translations "dashboard.modal.notify_recovery_checkbox"}}</span>
    </label>

    <div class="modal-actions">
      <button class="button button-secondary" type="button" id="monitor-cancel">{{index $.Translations "dashboard.modal.cancel_button"}}</button>
      <button class="button" type="submit">{{index $.Translations "dashboard.modal.save_button"}}</button>
    </div>
  </form>
</dialog>
{{end}}

{{if .IsAdmin}}
<dialog id="group-modal" class="monitor-modal group-modal">
  <form method="post" action="{{$.AppBase}}groups/save" class="stack" id="group-form" enctype="multipart/form-data">
    <input type="hidden" name="group" id="group-name-field">
    <input type="hidden" name="trend" value="{{.TrendValue}}">
    <input type="hidden" name="icon_slug" id="group-icon-slug">

    <div class="modal-header">
      <div>
        <h2 id="group-modal-title">{{index $.Translations "dashboard.group_modal.title"}}</h2>
        <p class="muted compact">{{index $.Translations "dashboard.group_modal.subtitle"}}</p>
      </div>
      <button class="modal-close-button" type="button" id="group-cancel" aria-label="{{index $.Translations "dashboard.group_modal.close_aria"}}">×</button>
    </div>

    <label>
      <span>{{index $.Translations "dashboard.group_modal.name_label"}}</span>
      <input type="text" name="new_name" id="group-new-name-field" required autocomplete="off" spellcheck="false">
    </label>

    <div class="group-icon-preview-panel">
      <div class="group-icon-preview-frame" id="group-icon-preview-frame" hidden>
        <img id="group-icon-preview" alt="{{index $.Translations "dashboard.group_modal.icon_preview_alt"}}">
      </div>
      <p class="muted compact">{{index $.Translations "dashboard.group_modal.preview_source"}}</p>
    </div>

    <label>
      <span>{{index $.Translations "dashboard.group_modal.search_label"}}</span>
      <input type="search" id="group-icon-search" placeholder="{{index $.Translations "dashboard.group_icon.search_placeholder"}}" autocomplete="off" spellcheck="false">
    </label>

    <p class="muted compact" id="group-icon-search-status">{{index $.Translations "dashboard.group_modal.search_hint"}}</p>
    <div class="group-icon-results" id="group-icon-results" aria-live="polite"></div>

    <label>
      <span>{{index $.Translations "dashboard.group_modal.upload_label"}}</span>
      <input type="file" id="group-icon-upload" name="icon_upload" accept=".svg,image/svg+xml,.png,image/png,.webp,image/webp,.jpg,.jpeg,image/jpeg,.ico,image/x-icon,image/vnd.microsoft.icon">
    </label>
    <p class="muted compact">{{index $.Translations "dashboard.group_modal.upload_hint"}}</p>

    <label>
      <span>{{index $.Translations "dashboard.group_modal.custom_slug_label"}}</span>
      <input type="text" id="group-icon-custom" placeholder="{{index $.Translations "dashboard.group_icon.custom_placeholder"}}">
    </label>

    <p class="muted compact" id="group-icon-selection">{{index $.Translations "dashboard.group_modal.no_icon_selected"}}</p>

    <div class="modal-actions">
      <button class="button button-secondary" type="button" id="group-reset-icon">{{index $.Translations "dashboard.group_modal.remove_icon"}}</button>
      <button class="button" type="submit">{{index $.Translations "dashboard.modal.save_button"}}</button>
    </div>
  </form>
</dialog>
{{end}}

<dialog id="trend-detail-modal" class="monitor-modal trend-detail-modal">
  <div class="stack">
    <div class="modal-header">
      <div>
        <h2 id="trend-detail-title">{{index $.Translations "dashboard.trend_detail.title"}}</h2>
        <p class="muted compact" id="trend-detail-subtitle">{{index $.Translations "dashboard.trend_detail.history"}}</p>
      </div>
      <button class="modal-close-button" type="button" id="trend-detail-close" aria-label="{{index $.Translations "dashboard.trend_detail.close_aria"}}">×</button>
    </div>

    <div class="trend-detail-meta">
      <article class="card trend-detail-card">
        <span class="muted">{{index $.Translations "common.status"}}</span>
        <strong id="trend-detail-status">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">{{index $.Translations "dashboard.trend_detail.uptime"}}</span>
        <strong id="trend-detail-uptime">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">{{index $.Translations "dashboard.trend_detail.last_check"}}</span>
        <strong id="trend-detail-last-check">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">{{index $.Translations "dashboard.trend_detail.latency_triplet"}}</span>
        <strong id="trend-detail-latency">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">{{index $.Translations "dashboard.trend_detail.checks"}}</span>
        <strong id="trend-detail-checks">—</strong>
      </article>
      <article class="card trend-detail-card">
        <span class="muted">{{index $.Translations "dashboard.modal.target_label"}}</span>
        <strong id="trend-detail-target">—</strong>
      </article>
    </div>

    <section class="card stack">
      <h3 id="trend-detail-range-title">{{index $.Translations "dashboard.trend_detail.range"}}</h3>
      <div id="trend-detail-bars" class="trend-bars trend-bars-large"></div>
      <div class="trend-detail-latency-chart" id="trend-detail-latency-chart" hidden>
        <div class="trend-detail-latency-chart-head">
          <strong>{{index $.Translations "dashboard.trend_detail.latency"}}</strong>
          <div class="trend-detail-latency-ranges" role="tablist" aria-label="{{index $.Translations "dashboard.trend_detail.latency_range"}}">
            <button class="button button-small trend-detail-latency-range" type="button" data-range="1h" aria-pressed="true">1h</button>
            <button class="button button-small button-secondary trend-detail-latency-range" type="button" data-range="6h" aria-pressed="false">6h</button>
            <button class="button button-small button-secondary trend-detail-latency-range" type="button" data-range="24h" aria-pressed="false">24h</button>
            <button class="button button-small button-secondary trend-detail-latency-range" type="button" data-range="7d" aria-pressed="false">7d</button>
          </div>
        </div>
        <div class="trend-detail-latency-layout">
          <div class="trend-detail-latency-plot" id="trend-detail-latency-plot">
            <div class="trend-detail-latency-tooltip" id="trend-detail-latency-tooltip" hidden></div>
          </div>
          <div class="trend-detail-latency-axis trend-detail-latency-axis-y" aria-hidden="true">
            <span id="trend-detail-latency-y-max">—</span>
            <span id="trend-detail-latency-y-mid">—</span>
            <span id="trend-detail-latency-y-min">0 ms</span>
          </div>
        </div>
        <div class="trend-detail-latency-axis trend-detail-latency-axis-x" aria-hidden="true">
          <span id="trend-detail-latency-x-start">—</span>
          <span id="trend-detail-latency-x-end">—</span>
        </div>
        <p class="muted compact" id="trend-detail-latency-caption">—</p>
      </div>
    </section>

    <section class="card stack">
      <h3>{{index $.Translations "dashboard.trend_detail.history"}}</h3>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>{{index $.Translations "dashboard.trend_detail.period"}}</th>
              <th>{{index $.Translations "dashboard.trend_detail.result"}}</th>
            </tr>
          </thead>
          <tbody id="trend-detail-history"></tbody>
        </table>
      </div>
    </section>
  </div>
</dialog>

<section id="dashboard-live-board" class="card stack dashboard-board">
  {{range .MonitorGroups}}
  <section class="monitor-group {{.AccentClass}} stack">
    {{if .Monitors}}
      <div class="service-group-list">
        {{range .Services}}
        {{$serviceTitle := .Title}}
        <details class="service-cluster" {{if .Open}}open{{end}} {{if $.IsAdmin}}draggable="true"{{end}} data-group="{{.Title}}">
          <summary class="service-cluster-header">
            <div class="service-summary">
              <div class="service-summary-top">
                <div class="service-cluster-title">
                  {{if .IconURL}}
                  <img class="group-icon" src="{{.IconURL}}" alt="{{.Title}} Icon" loading="lazy" referrerpolicy="no-referrer">
                  {{end}}
                  <div>
                    <h4>{{.Title}}</h4>
                  </div>
                </div>
                <div class="service-summary-right">
                  <span class="service-count" aria-label="{{printf (index $.Translations "dashboard.group.monitor_count_aria") (len .Monitors)}}">{{len .Monitors}}</span>
                  <span class="status-pill {{.StatusClass}}">{{.StatusLabel}}</span>
                  {{if $.IsAdmin}}
                  <details class="action-menu">
                  <summary class="action-menu-trigger" aria-label="{{printf (index $.Translations "dashboard.group.actions_aria") .Title}}">⋯</summary>
                  <div class="action-menu-list">
                    <button
                      class="action-menu-item group-settings"
                      type="button"
                      data-group="{{.Title}}"
                      data-icon-slug="{{.IconSlug}}"
                      aria-label="{{printf (index $.Translations "dashboard.group.configure_icon_aria") .Title}}">{{index $.Translations "dashboard.group.settings"}}</button>
                    <form method="post" action="{{$.AppBase}}groups/delete" class="action-menu-form" data-confirm="{{index $.Translations "dashboard.group.delete_confirm"}}">
                      <input type="hidden" name="group" value="{{.Title}}">
                      <button class="action-menu-item action-menu-item-danger" type="submit">{{index $.Translations "dashboard.group.delete"}}</button>
                    </form>
                  </div>
                </details>
                  {{end}}
                </div>
              </div>
              {{if .TrendPoints}}
              <button
                class="trend-trigger service-summary-trend"
                type="button"
                data-monitor-name="{{.Title}}"
                data-monitor-kind="{{index $.Translations "dashboard.group.kind_service"}}"
                data-target="{{.Title}}"
                data-status="{{.StatusLabel}}"
                data-uptime="{{.UptimeLabel}}"
                data-trend-label="{{.TrendLabel}}"
                data-last-check=""
                data-last-message="{{.StatusInfo}}"
                aria-label="{{printf (index $.Translations "dashboard.trend_detail.open_for") .Title}}">
                <div class="trend-bars" aria-label="{{printf (index $.Translations "dashboard.trend.aria") .TrendLabel}}">
                  {{range .TrendPoints}}
                  <span class="trend-bar {{.Class}}" data-bucket="{{.BucketRaw}}" data-label="{{.Label}}" data-format="{{.Format}}" data-checks="{{.Checks}}" data-latency-checks="{{.LatencyChecks}}" data-avg-ms="{{.AvgMS}}" data-min-ms="{{.MinMS}}" data-max-ms="{{.MaxMS}}"></span>
                  {{end}}
                </div>
              </button>
              {{else}}
              <p class="muted compact">{{index $.Translations "dashboard.group.no_monitors"}}</p>
              {{end}}
            </div>
          </summary>
          <div class="monitor-grid">
      {{range .Monitors}}
      <article class="card monitor-card {{.StatusClass}}" {{if $.IsAdmin}}draggable="true"{{end}} data-monitor-id="{{.ID}}" data-group="{{$serviceTitle}}" data-interval-seconds="{{.IntervalSeconds}}" data-last-check="{{.LastCheckedAtRaw}}">
        <div class="monitor-card-header">
          <div>
              <h5>{{.Name}}</h5>
            <p class="muted compact">{{.Kind}}{{if .TLSMode}} / {{.TLSMode}}{{end}} · {{index $.Translations "dashboard.monitor.every"}} {{.Interval}} · {{index $.Translations "dashboard.monitor.timeout"}} {{.Timeout}}</p>
          </div>
          <div class="monitor-header-right">
            {{if and $.IsAdmin (ne .ExecutorKind "remote")}}
            <button
              class="monitor-cycle-indicator monitor-cycle-trigger"
              type="button"
              data-check-monitor-id="{{.ID}}"
              aria-label="{{printf (index $.Translations "dashboard.monitor.check_now_aria") .Name}}"
              title="{{index $.Translations "dashboard.monitor.check_now"}}"></button>
            {{else}}
            <span class="monitor-cycle-indicator" aria-hidden="true"></span>
            {{end}}
            <span class="status-pill {{.StatusClass}}">{{.StatusLabel}}</span>
            {{if $.IsAdmin}}
            <details class="action-menu">
              <summary class="action-menu-trigger" aria-label="{{printf (index $.Translations "dashboard.monitor.actions_aria") .Name}}">⋯</summary>
              <div class="action-menu-list">
                <button
                  class="action-menu-item edit-monitor"
                  type="button"
                  data-id="{{.ID}}"
                  data-name="{{.Name}}"
                  data-group="{{.Group}}"
                  data-kind="{{.KindValue}}"
                  data-tls-mode="{{.TLSModeValue}}"
                  data-target="{{.Target}}"
                  data-executor="{{.ExecutorValue}}"
                  data-interval="{{.IntervalSeconds}}"
                  data-timeout="{{.TimeoutSeconds}}"
                  data-enabled="{{if .Enabled}}1{{else}}0{{end}}"
                  data-notify-on-recovery="{{if .NotifyOnRecovery}}1{{else}}0{{end}}"
                  data-expected-status="{{.ExpectedStatus}}"
                  data-expected-text="{{.ExpectedText}}">
                  {{index $.Translations "common.edit"}}
                </button>
                <form method="post" action="{{$.AppBase}}monitors/enabled" class="action-menu-form">
                  <input type="hidden" name="id" value="{{.ID}}">
                  <input type="hidden" name="enabled" value="{{if .Enabled}}0{{else}}1{{end}}">
                  <button class="action-menu-item" type="submit">{{if .Enabled}}{{index $.Translations "dashboard.monitor.pause"}}{{else}}{{index $.Translations "dashboard.monitor.enable"}}{{end}}</button>
                </form>
                <form method="post" action="{{$.AppBase}}monitors/delete" class="action-menu-form" data-confirm="{{index $.Translations "dashboard.monitor.delete_confirm"}}">
                  <input type="hidden" name="id" value="{{.ID}}">
                  <button class="action-menu-item action-menu-item-danger" type="submit">{{index $.Translations "common.delete"}}</button>
                </form>
              </div>
            </details>
            {{end}}
          </div>
        </div>

        <button
          class="trend-trigger monitor-summary-trend"
          type="button"
          data-monitor-id="{{.ID}}"
          data-monitor-name="{{.Name}}"
          data-monitor-kind="{{.Kind}}"
          data-target="{{.TargetLabel}}"
          data-status="{{.StatusLabel}}"
          data-uptime="{{.UptimeLabel}}"
          data-trend-label="{{.TrendLabel}}"
          data-last-check="{{.LastCheckedAtRaw}}"
          data-last-message="{{.LastMessage}}"
          aria-label="{{printf (index $.Translations "dashboard.trend_detail.open_for") .Name}}">
          <div class="trend-bars" aria-label="{{printf (index $.Translations "dashboard.trend.aria") .TrendLabel}}">
            {{range .TrendPoints}}
            <span class="trend-bar {{.Class}}" data-bucket="{{.BucketRaw}}" data-label="{{.Label}}" data-format="{{.Format}}" data-checks="{{.Checks}}" data-latency-checks="{{.LatencyChecks}}" data-avg-ms="{{.AvgMS}}" data-min-ms="{{.MinMS}}" data-max-ms="{{.MaxMS}}"></span>
            {{end}}
          </div>
        </button>

        <div class="monitor-card-body stack compact-stack">
          <div class="info-row">
            <span class="muted">{{index $.Translations "dashboard.modal.target_label"}}</span>
            <strong class="break-all">{{.TargetLabel}}</strong>
          </div>
          <div class="info-row">
            <span class="muted">{{index $.Translations "common.status"}}</span>
            <strong>{{.StatusSummary}}</strong>
          </div>
          {{if $.HasRemoteNodes}}
          <div class="info-row">
            <span class="muted">{{index $.Translations "dashboard.monitor.executor"}}</span>
            <strong>{{.ExecutorLabel}}</strong>
          </div>
          {{end}}

          <div class="monitor-metrics">
            <div class="monitor-metric">
              <span class="muted">{{index $.Translations "dashboard.trend_detail.latency"}}</span>
              <strong>{{if .LastLatency}}{{.LastLatency}}{{else}}—{{end}}</strong>
            </div>
            {{if eq .KindValue "https"}}
            <div class="monitor-metric">
              <span class="muted">HTTP</span>
              <strong>{{if .HTTPStatusCode}}{{.HTTPStatusCode}}{{else}}—{{end}}</strong>
            </div>
            {{end}}
            <div class="monitor-metric">
              <span class="muted">{{index $.Translations "dashboard.trend_detail.last_check"}}</span>
              <strong>{{if .LastCheckedAtRaw}}<time class="client-time" datetime="{{.LastCheckedAtRaw}}" data-format="relative-age">{{.LastCheckedAt}}</time>{{else}}—{{end}}</strong>
            </div>
            {{if eq .KindValue "https" "tcp" "smtp" "imap"}}
            <div class="monitor-metric">
              <span class="muted">{{index $.Translations "dashboard.monitor.certificate"}}</span>
              <strong>{{if .TLSNotAfterRaw}}<time class="client-time" datetime="{{.TLSNotAfterRaw}}" data-format="minute">{{.TLSNotAfter}}</time>{{else}}—{{end}}</strong>
              {{if .TLSDaysRemaining}}<span class="muted compact">{{.TLSDaysRemaining}} {{index $.Translations "dashboard.monitor.remaining"}}</span>{{end}}
            </div>
            {{else if eq .KindValue "whois"}}
            <div class="monitor-metric">
              <span class="muted">{{index $.Translations "dashboard.monitor.domain_expiry"}}</span>
              <strong>{{if .TLSNotAfterRaw}}<time class="client-time" datetime="{{.TLSNotAfterRaw}}" data-format="minute">{{.TLSNotAfter}}</time>{{else}}—{{end}}</strong>
              {{if .TLSDaysRemaining}}<span class="muted compact">{{.TLSDaysRemaining}} {{index $.Translations "dashboard.monitor.remaining"}}</span>{{end}}
            </div>
            {{end}}
          </div>

        </div>
      </article>
      {{end}}
          </div>
        </details>
        {{end}}
    </div>
    {{else}}
    <p class="muted">{{.EmptyText}}</p>
    {{end}}
  </section>
  {{end}}
</section>

<section id="dashboard-live-state-events" class="card stack notification-events-card">
  <h2>{{index $.Translations "dashboard.state_events.title"}}</h2>
  {{if .StateEvents}}
  <div class="state-events-toolbar">
    <label>
      <span class="sr-only">{{index $.Translations "dashboard.state_events.search_sr"}}</span>
      <input type="search" id="state-events-search" placeholder="{{index $.Translations "dashboard.state_events.search_placeholder"}}" autocomplete="off" spellcheck="false">
    </label>
    <label>
      <span class="sr-only">{{index $.Translations "dashboard.state_events.filter_status_sr"}}</span>
      <select id="state-events-status-filter">
        <option value="all">{{index $.Translations "dashboard.state_events.status_all"}}</option>
        <option value="down">DOWN</option>
        <option value="degraded">DEGRADED</option>
        <option value="up">UP</option>
      </select>
    </label>
    <label class="checkbox-row">
      <input type="checkbox" id="state-events-incidents-only">
      <span>{{index $.Translations "dashboard.state_events.incidents_only"}}</span>
    </label>
    <button class="button button-secondary button-small" type="button" id="state-events-export">{{index $.Translations "dashboard.state_events.export_csv"}}</button>
  </div>
  <p class="muted compact" id="state-events-filter-status"></p>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>{{index $.Translations "dashboard.state_events.time"}}</th>
          <th>{{index $.Translations "dashboard.state_events.monitor"}}</th>
          <th>{{index $.Translations "dashboard.state_events.from"}}</th>
          <th>{{index $.Translations "dashboard.state_events.to"}}</th>
          <th>{{index $.Translations "dashboard.state_events.details"}}</th>
        </tr>
      </thead>
      <tbody id="state-events-body">
        {{range .StateEvents}}
        <tr data-monitor="{{.Monitor}}" data-from="{{.From}}" data-to="{{.To}}" data-message="{{.Message}}" data-when="{{.WhenRaw}}">
          <td><time class="client-time" datetime="{{.WhenRaw}}" data-format="datetime">{{.When}}</time></td>
          <td>{{.Monitor}}</td>
          <td><span class="status-pill {{.FromClass}}">{{.From}}</span></td>
          <td><span class="status-pill {{.ToClass}}">{{.To}}</span></td>
          <td class="break-all" title="{{.Message}}"><span class="event-message-cell">{{.Message}}</span></td>
        </tr>
        {{end}}
        <tr id="state-events-empty-row" hidden>
          <td colspan="5" class="muted">{{index $.Translations "dashboard.state_events.empty_filtered"}}</td>
        </tr>
      </tbody>
    </table>
  </div>
  <div class="table-pagination" id="state-events-pagination" hidden></div>
  {{else}}
  <p class="muted">{{index $.Translations "dashboard.state_events.empty"}}</p>
  {{end}}
</section>

<section id="dashboard-live-notification-events" class="card stack notification-events-card">
  <h2>{{index $.Translations "dashboard.notification_events.title"}}</h2>
  {{if .Events}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>{{index $.Translations "dashboard.notification_events.time"}}</th>
          <th>{{index $.Translations "dashboard.notification_events.monitor"}}</th>
          <th>{{index $.Translations "dashboard.notification_events.event"}}</th>
          <th>{{index $.Translations "dashboard.notification_events.endpoint"}}</th>
          <th>{{index $.Translations "dashboard.notification_events.result"}}</th>
          <th>{{index $.Translations "dashboard.notification_events.error"}}</th>
          <th>{{index $.Translations "dashboard.notification_events.delivered"}}</th>
        </tr>
      </thead>
      <tbody id="notification-events-body">
        {{range .Events}}
        <tr>
          <td><time class="client-time" datetime="{{.WhenRaw}}" data-format="datetime">{{.When}}</time></td>
          <td>{{.Monitor}}</td>
          <td>{{.EventType}}</td>
          <td title="{{.Endpoint}}"><span class="notification-endpoint-cell">{{.Endpoint}}</span></td>
          <td title="{{.Result}}"><span class="notification-result-cell">{{.Result}}</span></td>
          <td class="break-all" title="{{.Error}}"><span class="notification-error-cell">{{.Error}}</span></td>
          <td>{{if .DeliveredAtRaw}}<time class="client-time" datetime="{{.DeliveredAtRaw}}" data-format="datetime">{{.DeliveredAt}}</time>{{else}}—{{end}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  <div class="table-pagination" id="notification-events-pagination" hidden></div>
  {{else}}
  <p class="muted">{{index $.Translations "dashboard.notification_events.empty"}}</p>
  {{end}}
</section>
</div>
{{end}}


{{define "content"}}
<section class="login-shell">
  <a class="login-brand" href="{{if .AppBase}}{{.AppBase}}{{else}}/{{end}}" aria-label="{{index $.Translations "login.title"}}">
    <img class="login-brand-logo" src="/assets/logo_goup.svg" alt="GoUp Logo">
  </a>
  <article class="card login-card stack">
    <div>
      <h1>{{index $.Translations "login.title"}}</h1>
      {{if .TenantSlug}}
      <p class="muted">{{index $.Translations "login.tenant_label"}} <strong>{{.TenantName}}</strong> ({{.TenantSlug}})</p>
      {{else}}
      <p class="muted">{{index $.Translations "login.tenant_required"}}</p>
      {{end}}
    </div>

    {{if .Error}}
    <div class="notice error">{{.Error}}</div>
    {{end}}
    {{if .Notice}}
    <div class="notice success">{{.Notice}}</div>
    {{end}}

    {{if .TenantSlug}}
      {{if .HasOIDCLogin}}
      <div class="login-actions stack">
        {{range .LoginProviders}}
          {{if eq .Kind "oidc"}}
          <a class="button" href="/{{$.TenantSlug}}/auth/login?provider={{.ProviderKey}}">{{printf (index $.Translations "login.oidc_button") .DisplayName}}</a>
          {{end}}
        {{end}}
      </div>
      {{end}}

      {{if and .HasLocalLogin .HasOIDCLogin}}
      <div class="login-divider"><span>{{index $.Translations "login.or_local"}}</span></div>
      {{end}}

      {{if .HasLocalLogin}}
      <form method="POST" action="/{{.TenantSlug}}/auth/local" class="stack login-form">
        <label for="login_name">{{index $.Translations "login.username_label"}}</label>
        <input id="login_name" name="login_name" type="text" placeholder="{{index $.Translations "login.username_placeholder"}}" required autocomplete="username">
        <label for="password">{{index $.Translations "login.password_label"}}</label>
        <input id="password" name="password" type="password" placeholder="{{index $.Translations "login.password_placeholder"}}" required autocomplete="current-password">
        <button type="submit" class="button">{{index $.Translations "login.local_button"}}</button>
        {{if .ResetEnabled}}
        <a class="button button-secondary" href="/{{.TenantSlug}}/password-reset">{{index $.Translations "login.forgot_password"}}</a>
        {{end}}
      </form>
      {{end}}

      {{if and (not .HasLocalLogin) (not .HasOIDCLogin)}}
      <div class="notice warning">{{index $.Translations "login.no_login_configured"}}</div>
      {{end}}
    {{else}}
    <div class="notice warning">{{index $.Translations "login.tenant_required"}}</div>
    {{end}}
  </article>
</section>
{{end}}

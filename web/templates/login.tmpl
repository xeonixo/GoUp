{{define "content"}}
<section class="login-shell">
  <article class="card login-card stack">
    <div>
      <span class="eyebrow">GoUp Login</span>
      <h1>Anmeldung</h1>
      {{if .TenantSlug}}
      <p class="muted">Tenant: <strong>{{.TenantName}}</strong> ({{.TenantSlug}})</p>
      {{else}}
      <p class="muted">Bitte über die Tenant-Login-URL anmelden.</p>
      {{end}}
    </div>

    {{if .Error}}
    <div class="notice error">{{.Error}}</div>
    {{end}}
    {{if .Notice}}
    <div class="notice success">{{.Notice}}</div>
    {{end}}

    {{if .TenantSlug}}
      {{if .HasOIDCLogin}}
      <div class="login-actions stack">
        {{range .LoginProviders}}
          {{if eq .Kind "oidc"}}
          <a class="button" href="/{{$.TenantSlug}}/auth/login?provider={{.ProviderKey}}">Mit {{.DisplayName}} anmelden</a>
          {{end}}
        {{end}}
      </div>
      {{end}}

      {{if and .HasLocalLogin .HasOIDCLogin}}
      <div class="login-divider"><span>oder lokal anmelden</span></div>
      {{end}}

      {{if .HasLocalLogin}}
      <form method="POST" action="/{{.TenantSlug}}/auth/local" class="stack login-form">
        <label for="login_name">Benutzername</label>
        <input id="login_name" name="login_name" type="text" required autocomplete="username">
        <label for="password">Passwort</label>
        <input id="password" name="password" type="password" required autocomplete="current-password">
        <button type="submit" class="button">Lokal anmelden</button>
        {{if .ResetEnabled}}
        <a class="button button-secondary" href="/{{.TenantSlug}}/password-reset">Passwort vergessen?</a>
        {{end}}
      </form>
      {{end}}

      {{if and (not .HasLocalLogin) (not .HasOIDCLogin)}}
      <div class="notice warning">Für diesen Tenant ist keine Anmeldung konfiguriert.</div>
      {{end}}
    {{else}}
    <div class="notice warning">Bitte nutze die tenant-spezifische URL, z.B. <strong>/mein-tenant/login</strong>.</div>
    {{end}}
  </article>
</section>
{{end}}

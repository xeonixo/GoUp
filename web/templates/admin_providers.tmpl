{{define "content"}}
<div class="admin-section">
  <nav class="admin-nav card">
    <a href="/admin/" class="admin-nav-link">{{index $.Translations "admin.nav.general"}}</a>
    <a href="/admin/tenants" class="admin-nav-link">{{index $.Translations "admin.nav.tenants"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/providers" class="admin-nav-link is-active">{{index $.Translations "admin.nav.providers"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/local-users" class="admin-nav-link">{{index $.Translations "admin.nav.users"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/remote-nodes" class="admin-nav-link">{{index $.Translations "admin.nav.remote_nodes"}}</a>
  </nav>

  {{if .Notice}}<div class="notice success">{{.Notice}}</div>{{end}}
  {{if .Error}}<div class="notice error">{{.Error}}</div>{{end}}

  <div class="admin-header">
    <div>
      <h1>{{index $.Translations "admin.nav.providers"}} · {{.AdminTenant.Name}}</h1>
    </div>
    <a href="/admin/tenants" class="button button-secondary">{{index $.Translations "admin.providers.back_to_tenants"}}</a>
  </div>

  <div class="card table-card">
  <table class="admin-table">
    <thead>
      <tr>
        <th>{{index $.Translations "admin.providers.provider_key"}}</th>
        <th>{{index $.Translations "common.type"}}</th>
        <th>{{index $.Translations "common.name"}}</th>
        <th>{{index $.Translations "common.status"}}</th>
        <th>{{index $.Translations "common.actions"}}</th>
      </tr>
    </thead>
    <tbody>
      {{if .AdminProviders}}
      {{range .AdminProviders}}
      <tr>
        <td>{{.ProviderKey}}</td>
        <td><span class="status-badge">{{.Kind}}</span></td>
        <td>{{.DisplayName}}</td>
        <td>
          {{if .Enabled}}
          <span class="status-badge status-badge-success">{{index $.Translations "common.active"}}</span>
          {{else}}
          <span class="status-badge status-badge-muted">{{index $.Translations "common.inactive"}}</span>
          {{end}}
        </td>
        <td class="admin-actions-inline">
          {{if ne .Kind "local"}}
          <a href="/admin/tenants/{{$.AdminTenant.ID}}/providers/{{.ProviderKey}}/edit" class="button button-secondary button-small">{{index $.Translations "common.edit"}}</a>
          {{end}}
          {{if .Enabled}}
          <form method="POST" action="/admin/tenants/{{$.AdminTenant.ID}}/providers/{{.ProviderKey}}/delete" class="inline-form" data-confirm="{{index $.Translations "admin.providers.confirm_deactivate"}}">
            <button type="submit" class="button button-danger button-small">{{index $.Translations "admin.providers.deactivate"}}</button>
          </form>
          {{end}}
        </td>
      </tr>
      {{end}}
      {{else}}
      <tr>
        <td colspan="5" class="muted">{{index $.Translations "admin.providers.no_providers"}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  </div>

  <div class="admin-actions">
    <a href="/admin/tenants/{{.AdminTenant.ID}}/providers/new" class="button">+ {{index $.Translations "admin.providers.new_provider"}}</a>
    <a href="/admin/tenants/{{.AdminTenant.ID}}/local-users" class="button button-secondary">{{index $.Translations "admin.tenants.local_users"}}</a>
  </div>
</div>
{{end}}

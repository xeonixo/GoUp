GOUP_ADDR=:8080
GOUP_BASE_URL=http://localhost:8080
GOUP_DATA_DIR=/data
GOUP_DB_PATH=/data/goup.db
GOUP_LOG_LEVEL=info
GOUP_AUTH_MODE=disabled
GOUP_SESSION_KEY=change-me-32-bytes-or-more
GOUP_OIDC_ISSUER_URL=https://auth.example.com/application/o/goup/
GOUP_OIDC_CLIENT_ID=goup
GOUP_OIDC_CLIENT_SECRET=replace-me
GOUP_OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
GOUP_MATRIX_HOMESERVER_URL=https://matrix.example.com
GOUP_MATRIX_ACCESS_TOKEN=
GOUP_MATRIX_ROOM_ID=!roomid:example.com
